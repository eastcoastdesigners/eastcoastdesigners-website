---
import { Image } from 'astro:assets';
import PhoneLink from './PhoneLink.astro';
import logoMetallic from '../assets/logos/logo-metallic.png';

const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="East Coast Designers — home">
      <Image
        src={logoMetallic}
        alt="East Coast Designers"
        widths={[140, 280]}
        sizes="(min-width: 768px) 220px, 160px"
        loading="eager"
        class="logo-img"
      />
    </a>

    <nav aria-label="Primary" class="primary-nav">
      <ul>
        {navLinks.map((link) => {
          const isCurrent = currentPath === link.href;
          return (
            <li>
              <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <PhoneLink class="header-phone" />
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-navy);
    color: var(--color-white);
    border-bottom: 1px solid rgba(201, 169, 97, 0.15);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
    flex-wrap: wrap;
  }
  .logo-link { display: inline-flex; align-items: center; }
  .logo-img {
    height: 56px;
    width: auto;
    display: block;
  }
  .primary-nav {
    margin-left: auto;
  }
  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-3);
  }
  .primary-nav a {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-white);
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .primary-nav a:hover,
  .primary-nav a[aria-current='page'] {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }
  .header-phone {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    text-decoration: none;
    margin-left: var(--space-2);
  }
  .header-phone:hover { color: var(--color-white); }

  @media (max-width: 720px) {
    .header-inner { gap: var(--space-2); }
    .logo-img { height: 44px; }
    .primary-nav { width: 100%; margin-left: 0; }
    .primary-nav ul { gap: var(--space-2); justify-content: flex-start; }
    .primary-nav a { font-size: var(--text-xs); }
    .header-phone { margin-left: 0; }
  }
</style>
