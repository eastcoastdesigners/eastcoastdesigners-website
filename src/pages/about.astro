---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldRule from '../components/GoldRule.astro';

const title = 'About | East Coast Designers — Connecticut Renovation & Construction';
const description = 'A Connecticut renovation and construction firm focused on careful work, clear communication, and homes built to last.';
---
<BaseLayout title={title} description={description}>

  <section class="page-header section">
    <div class="container content">
      <span class="eyebrow">About</span>
      <h1>A Connecticut builder.</h1>
    </div>
  </section>

  <section class="section-tight">
    <div class="container content about-body">
      <p>
        East Coast Designers is a renovation and construction firm based in Connecticut,
        working with Connecticut homeowners only.
      </p>
      <p>
        We focus on the work — the framing, the finishes, the trades, the schedule.
        We're not a luxury concierge and we're not a giant national outfit. We're a
        Connecticut crew that does careful renovations and ground-up builds, one job at a time.
      </p>
      <p>
        If you're planning a renovation, an addition, or a new build, we'd be glad to come
        take a look at what you have in mind.
      </p>
    </div>
  </section>

  <section class="section section-bleed-offwhite">
    <div class="container content">
      <span class="eyebrow">How we work</span>
      <div class="principles-grid">
        <article class="principle">
          <GoldRule width="40px" />
          <h2>Clear scope, clear number.</h2>
          <p>Before we start, you know what we're doing, when we're starting, and what it costs.</p>
        </article>
        <article class="principle">
          <GoldRule width="40px" />
          <h2>One point of contact.</h2>
          <p>You're not chasing five subs. You call one number and get an answer.</p>
        </article>
        <article class="principle">
          <GoldRule width="40px" />
          <h2>Work that holds up.</h2>
          <p>We do the work behind the walls properly so the finishes you can see last.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section service-area">
    <div class="container content">
      <span class="eyebrow">Service area</span>
      <p class="service-area-statement">
        We work in Connecticut, statewide. We do not work outside of Connecticut.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header { padding-top: var(--space-8); padding-bottom: var(--space-6); }
  .about-body p { max-width: 65ch; margin-bottom: var(--space-3); }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-4);
  }
  .principle h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  .principle p {
    font-size: var(--text-base);
    color: var(--color-body);
    margin: 0;
  }

  .service-area-statement {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-navy);
    line-height: 1.3;
    max-width: 50ch;
    margin: var(--space-3) 0 0 0;
  }
</style>
