---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLink from '../components/PhoneLink.astro';
import TextLink from '../components/TextLink.astro';
import GoldRule from '../components/GoldRule.astro';

import constructionHero from '../assets/images/exterior-modern.jpg';
import kitchenHero from '../assets/images/kitchen-hero.jpg';
import kitchenDetail from '../assets/images/kitchen-detail.jpg';
import bathModern from '../assets/images/bath-modern.jpg';
import exteriorTraditional from '../assets/images/exterior-traditional.jpg';
import commercialLobby from '../assets/images/commercial-lobby.jpg';
import commercialOffice from '../assets/images/commercial-office.jpg';

const title = 'Construction — Additions, New Builds, Residential & Commercial | East Coast Designers';
const description = 'Construction practice: additions, ground-up new construction, whole-home renovations, and commercial buildouts. Residential and commercial. Based in Connecticut, working tri-state and select projects nationwide.';
---
<BaseLayout title={title} description={description}>

  <section class="page-hero">
    <Image
      src={constructionHero}
      alt="Residential exterior"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      class="page-hero-photo"
    />
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-inner">
      <span class="eyebrow page-hero-eyebrow">Construction</span>
      <h1>From the foundation up.</h1>
      <GoldRule width="64px" />
      <p class="page-hero-subhead">
        Additions, ground-up new construction, whole-home renovations, and commercial
        buildouts. Residential and commercial.
      </p>
    </div>
  </section>

  <section class="section services-block">
    <div class="container">
      <div class="services-header">
        <span class="eyebrow">What we build</span>
        <h2>Four service lines, one team running the job.</h2>
        <GoldRule width="64px" />
      </div>
      <div class="services-list">
        <article class="service-row">
          <span class="service-num">01</span>
          <div class="service-body">
            <h3>Additions</h3>
            <p>
              Bump-outs, second-story additions, in-law suites, sunrooms. We handle framing,
              mechanicals, and finishes, and tie the new space cleanly into the original
              structure.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">02</span>
          <div class="service-body">
            <h3>Ground-Up New Construction</h3>
            <p>
              Custom homes and commercial buildings built from the foundation up. We
              coordinate with your architect (or one of ours), manage permits and trades,
              and run the build from foundation to final walk-through.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">03</span>
          <div class="service-body">
            <h3>Whole-Home Renovations</h3>
            <p>
              Top-to-bottom renovations of existing homes. Demo, structural work,
              mechanicals, and finishes — kept organized so you're not living in chaos
              any longer than necessary.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">04</span>
          <div class="service-body">
            <h3>Commercial Buildouts</h3>
            <p>
              Commercial interiors and ground-up commercial construction. The same care
              that goes into a residential project, applied at commercial scale and
              schedule.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-bleed-offwhite process-section">
    <div class="container process-grid">
      <div class="process-left">
        <span class="eyebrow">How we work</span>
        <h2>From first walk-through to final punch list.</h2>
        <GoldRule width="56px" />
      </div>
      <div class="process-right">
        <article class="process-step">
          <span class="process-num">01</span>
          <div>
            <h3>Walk-through &amp; Scope</h3>
            <p>
              We visit the site, talk through what you want done, and put together a
              scope and a number you can plan around.
            </p>
          </div>
        </article>
        <article class="process-step">
          <span class="process-num">02</span>
          <div>
            <h3>Planning &amp; Permits</h3>
            <p>
              Drawings, permits, and the trades. You'll know who's doing what, when
              they're starting, and what it costs before we break ground.
            </p>
          </div>
        </article>
        <article class="process-step">
          <span class="process-num">03</span>
          <div>
            <h3>Build</h3>
            <p>
              Our crew runs the job. Single point of contact, regular check-ins, a job
              site that stays organized from demo to punch list.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section portfolio-section">
    <div class="container">
      <div class="portfolio-header">
        <span class="eyebrow">Work</span>
        <h2>Construction across residential and commercial.</h2>
      </div>
      <div class="portfolio-grid">
        <figure class="portfolio-tile">
          <Image
            src={kitchenHero}
            alt="Kitchen renovation"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Whole-home kitchen renovation</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={bathModern}
            alt="Bathroom renovation"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Primary bath renovation</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={exteriorTraditional}
            alt="Residential exterior"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Ground-up residential build</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={commercialLobby}
            alt="Commercial interior"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Commercial lobby buildout</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={kitchenDetail}
            alt="Kitchen renovation detail"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Kitchen finish detail</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={commercialOffice}
            alt="Commercial office interior"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Commercial office interior</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-bleed-navy closing-band">
    <div class="container content">
      <h2>Planning a construction project?</h2>
      <p class="closing-body">We'd be glad to come take a look. Call or send a request — we'll get back to you the same day.</p>
      <div class="closing-cta-row">
        <PhoneLink class="btn btn-primary closing-cta" prefix="Call " />
        <TextLink class="btn btn-ghost closing-cta-ghost" label="Request a consultation" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ----- PAGE HERO ----- */
  .page-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-white);
  }
  .page-hero-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .page-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(15,42,68,0.4) 0%, rgba(15,42,68,0.82) 100%);
    z-index: 1;
  }
  .page-hero-inner {
    position: relative; z-index: 2;
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    max-width: 820px;
  }
  .page-hero-eyebrow { color: var(--color-gold); margin-bottom: var(--space-3); }
  .page-hero h1 {
    color: var(--color-white);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .page-hero-subhead {
    color: var(--color-white);
    opacity: 0.94;
    margin-top: var(--space-3);
    font-size: clamp(var(--text-lg), 1.5vw, var(--text-xl));
    max-width: 56ch;
    line-height: 1.55;
  }

  /* ----- SERVICES BLOCK ----- */
  .services-block {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .services-header { max-width: 720px; margin-bottom: var(--space-8); }
  .services-header h2 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    line-height: 1.15;
    margin-top: var(--space-2);
  }
  .services-list { display: flex; flex-direction: column; gap: var(--space-6); max-width: 820px; }
  .service-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(15, 42, 68, 0.08);
  }
  .service-row:last-child { border-bottom: none; padding-bottom: 0; }
  .service-num {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    line-height: 1;
    opacity: 0.85;
  }
  .service-body h3 {
    font-size: var(--text-xl);
    margin-top: -0.15em;
    margin-bottom: var(--space-2);
    color: var(--color-navy);
  }
  .service-body p {
    font-size: var(--text-base);
    color: var(--color-body);
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }

  /* ----- PROCESS ----- */
  .process-section {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 960px) {
    .process-grid {
      grid-template-columns: 5fr 7fr;
      gap: clamp(var(--space-8), 8vw, var(--space-16));
      align-items: start;
    }
  }
  .process-left h2 {
    font-size: clamp(var(--text-3xl), 3.5vw, var(--text-4xl));
    line-height: 1.15;
    margin-bottom: var(--space-3);
    max-width: 18ch;
  }
  .process-right { display: flex; flex-direction: column; gap: var(--space-8); }
  .process-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(15, 42, 68, 0.08);
  }
  .process-step:last-child { border-bottom: none; padding-bottom: 0; }
  .process-num {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    line-height: 1;
    opacity: 0.85;
  }
  .process-step h3 {
    font-size: var(--text-xl);
    margin-top: -0.15em;
    margin-bottom: var(--space-2);
  }
  .process-step p {
    font-size: var(--text-base);
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }

  /* ----- PORTFOLIO ----- */
  .portfolio-section {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
    background-color: var(--color-white);
  }
  .portfolio-header { max-width: 720px; margin-bottom: var(--space-8); }
  .portfolio-header h2 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    line-height: 1.15;
    margin-top: var(--space-2);
  }
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  }
  @media (min-width: 1200px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr 1fr; }
  }
  .portfolio-tile { margin: 0; }
  .portfolio-tile :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    display: block;
  }
  .portfolio-tile figcaption {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: var(--label-letter-spacing);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: var(--space-2);
  }

  /* ----- CLOSING ----- */
  .closing-band { text-align: center; padding-top: var(--space-16); padding-bottom: var(--space-16); }
  .closing-band h2 {
    margin-bottom: var(--space-3);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
  }
  .closing-body {
    color: var(--color-white);
    opacity: 0.94;
    margin-bottom: var(--space-6);
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }
  .closing-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }
  .closing-cta {
    background-color: var(--color-white);
    color: var(--color-navy);
    border-color: var(--color-white);
    padding: 14px 32px;
    text-decoration: none;
  }
  .closing-cta:hover {
    background-color: transparent;
    color: var(--color-white);
    border-color: var(--color-gold);
  }
  .closing-cta-ghost {
    background-color: transparent;
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
    padding: 14px 32px;
    text-decoration: none;
  }
  .closing-cta-ghost:hover {
    background-color: transparent;
    color: var(--color-gold);
    border-color: var(--color-gold);
  }
</style>
