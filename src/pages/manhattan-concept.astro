---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldRule from '../components/GoldRule.astro';
import PhoneLink from '../components/PhoneLink.astro';

// Emirates reference photos (Dubai + London, ribbon-cutting + interiors)
import londonRibbon from '../assets/images/emirates/london-exterior-ribbon.jpg';
import londonCurved from '../assets/images/emirates/london-curved-exterior.jpg';
import dubaiReception from '../assets/images/emirates/dubai-reception-red-chairs.jpg';
import dubaiFloorWide from '../assets/images/emirates/dubai-floor-wide.jpg';
import dubaiOverview from '../assets/images/emirates/dubai-overview.jpg';
import dubaiDisplayNiche from '../assets/images/emirates/dubai-display-niche.jpg';
import dubaiTreeWall from '../assets/images/emirates/dubai-tree-wall.jpg';
import mallStorefront from '../assets/images/emirates/mall-storefront.jpg';

// "Our Manhattan vision" — selected to read as MORE LUXURIOUS, MOODIER, MORE HISTORIC
// than Emirates' light-modern current aesthetic. Mix of AI commercial library + real
// ECD project photography from Google Business. Will be replaced with dedicated
// Manhattan-vision renders once kie.ai credits allow.
import ourBathMarbleBrass from '../assets/images/commercial-bath-marble-brass.jpg';
import ourBathDarkStone from '../assets/images/commercial-bath-dark-stone.jpg';
import ourDrywallCove from '../assets/images/commercial-drywall-cove.jpg';
import ourLibraryClub from '../assets/images/commercial-library-club.jpg';
import ourStorefrontBoutique from '../assets/images/commercial-storefront-boutique.jpg';
import ourLightingPendant from '../assets/images/commercial-lighting-pendant.jpg';
import ourCafeWalnut from '../assets/images/commercial-cafe-walnut.jpg';
import ourExecutiveLeather from '../assets/images/commercial-executive-leather.jpg';
import ourLibraryReading from '../assets/images/commercial-library-reading.jpg';
// Real ECD project shots — designer-grade editorial work
import realBathSputnik from '../assets/images/real-bath-sputnik.jpg';
import realBathVaultedRustic from '../assets/images/real-bath-vaulted-rustic.jpg';
import realKitchenCopper from '../assets/images/real-kitchen-copper.jpg';

const title = 'Manhattan Concept — Emirates World | East Coast Designers';
const description = 'Concept presentation for the Manhattan Emirates World travel store. By private invitation only.';

// SHA-256 of the access code. Same password as /our-work (Travertine-9248).
const PASSWORD_HASH = 'd4be9857c495efcc30655f835072f6ea9d2a4574838b47a3d3c262899ebaee5e';
---
<BaseLayout title={title} description={description} noindex={true}>

  {/* PASSWORD GATE */}
  <div id="mc-gate" class="mc-gate" role="dialog" aria-modal="true" aria-labelledby="mc-gate-title">
    <div class="mc-gate-card">
      <span class="eyebrow mc-gate-eyebrow">Private Concept Presentation</span>
      <h2 id="mc-gate-title" class="display display-italic mc-gate-headline">
        East Coast Designers
      </h2>
      <p class="mc-gate-blurb">
        Manhattan concept for Emirates World &mdash; by private invitation only.
        Please enter the access code provided to you.
      </p>
      <form id="mc-gate-form" autocomplete="off">
        <input
          type="password"
          id="mc-gate-input"
          name="passcode"
          placeholder="Access code"
          autocomplete="off"
          required
          aria-label="Access code"
        />
        <button type="submit" class="btn btn-primary mc-gate-submit">Enter</button>
      </form>
      <p id="mc-gate-error" class="mc-gate-error" hidden>
        Incorrect access code. Please try again.
      </p>
      <p class="mc-gate-foot">
        Shared by private invitation only. Not for redistribution.
        &copy; East Coast Designers &mdash; all rights reserved.
      </p>
    </div>
  </div>

  <div id="mc-content">

  {/* PRIVATE NOTICE */}
  <aside class="mc-private-notice" role="note" aria-label="Private concept presentation">
    <div class="container mc-private-notice-inner">
      <span class="mc-private-notice-tag">Private &amp; Confidential</span>
      <span class="mc-private-notice-text">
        Concept presentation, working draft. Shared by private invitation only.
        Please do not forward or redistribute without written request.
      </span>
    </div>
  </aside>

  {/* HERO */}
  <section class="mc-hero">
    <Image
      src={dubaiTreeWall}
      alt="Emirates Dubai store — Ghaf Tree illuminated feature wall"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      class="mc-hero-bg"
    />
    <div class="mc-hero-overlay"></div>
    <div class="container mc-hero-inner reveal">
      <span class="eyebrow mc-hero-eyebrow">Concept Presentation</span>
      <h1 class="display display-italic mc-hero-headline">
        Manhattan Emirates World &mdash; <em>a concept</em>.
      </h1>
      <GoldRule width="80px" />
      <p class="mc-hero-subhead">
        A private-jet sensibility, brought downstairs and made accessible.
      </p>
      <button id="mc-listen" class="mc-listen-btn" type="button" aria-label="Listen to the pitch in a feminine voice">
        <span class="mc-listen-icon" aria-hidden="true">&#9654;</span>
        <span class="mc-listen-text">Listen to the pitch</span>
      </button>
      <div id="mc-listen-status" class="mc-listen-status" aria-live="polite"></div>
    </div>
  </section>

  {/* INTRO — DESIGN INTENT */}
  <section class="section mc-intent">
    <div class="container content reveal">
      <span class="eyebrow">Design Intent</span>
      <h2 class="display display-italic mc-intent-headline">
        Emirates does not need to remind anyone that it is luxurious.
      </h2>
      <p class="mc-intent-lead">
        Emirates&rsquo; job, in this room, is to let the customer feel
        luxurious. Most of the customers who walk into this store will never
        fly private. The closest experience they will ever have to private
        aviation is the moment they walk through this door. The store IS the
        cabin upgrade.
      </p>
      <p>
        Every material, every light, every chair, every detail is calibrated
        so the customer feels that <em>they</em> are what is being showcased.
        That is the design intent. Everything else follows from there.
      </p>
    </div>
  </section>

  {/* WHAT EMIRATES HAS BUILT */}
  <section class="section mc-existing">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter I</span>
        <h2 class="display display-italic mc-section-headline">
          What Emirates has built.
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          Dubai (2022). London (2024). The DNA is clear: light, open, curved,
          lounge-like, anchored by the Ghaf Tree. Modern light furniture, blonde
          oak floors, vertical reeded walls, greenery as architecture. Red as
          accent only. This works. Manhattan must honor it.
        </p>
      </div>

      <div class="mc-gallery reveal">
        <figure class="mc-gallery-item mc-gallery-feature">
          <Image src={dubaiOverview} alt="Dubai store wide overview with curved white forms, blonde oak floor, red accent chairs, plants" widths={[800, 1200, 1800]} sizes="(min-width: 900px) 66vw, 100vw" loading="lazy" />
          <figcaption>Dubai &mdash; the open-plan, lounge-like floor</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={dubaiTreeWall} alt="Ghaf Tree illuminated on a brown feature wall" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>Dubai &mdash; the Ghaf Tree feature wall</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={dubaiReception} alt="Curved white reception pods with red swan chairs" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>Dubai &mdash; curved reception pods</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={dubaiFloorWide} alt="Wide Dubai floor with brass Emirates logo, oak floor, plants in white planters" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>Dubai &mdash; blonde oak + brass Emirates wordmark</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={dubaiDisplayNiche} alt="Display niche carved into vertical wood slat wall" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>Dubai &mdash; reeded slat wall with display niche</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={londonRibbon} alt="London exterior at ribbon-cutting with Emirates signage and red rose arrangements" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>London &mdash; opening day, Cromwell Road</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={londonCurved} alt="London exterior with curved corner facade and Emirates signage on limestone" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>London &mdash; curved facade on limestone</figcaption>
        </figure>
        <figure class="mc-gallery-item">
          <Image src={mallStorefront} alt="Emirates mall storefront with full-height glass and arched canopy" widths={[600, 900]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
          <figcaption>Mall storefront &mdash; full-height glass entrance</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {/* OUR MANHATTAN EVOLUTION — comparison cards */}
  <section class="section mc-evolution">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter II</span>
        <h2 class="display display-italic mc-section-headline">
          Our Manhattan evolution.
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          Same Emirates concept. Translated into a Manhattan vocabulary.
          <strong>More luxe. More history. More restraint.</strong> Pre-war
          architecture. Hand-finished materials. Warmer, dimmer light. A
          sculpted gold tree-branch chandelier where the wall tree once was.
          The sensory upgrade that turns a retail floor into a private cabin.
        </p>
      </div>

      {/* Comparison 1 — Tree wall → Sculpted gold chandelier overhead */}
      <div class="mc-compare reveal">
        <div class="mc-compare-side">
          <span class="mc-compare-tag">Currently</span>
          <Image src={dubaiTreeWall} alt="Dubai Ghaf Tree illuminated on the wall" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Wall-mounted illuminated Ghaf Tree on a brown accent wall &mdash; a 2D treatment in a single plane.</p>
        </div>
        <div class="mc-compare-arrow" aria-hidden="true">&#10142;</div>
        <div class="mc-compare-side">
          <span class="mc-compare-tag mc-compare-tag-our">Our Manhattan Evolution</span>
          <Image src={realBathSputnik} alt="Designer interior with sculptural chandelier and arched architectural moment" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">A <strong>sculpted polished-gold tree-branch chandelier with hand-strung crystal accents</strong> &mdash; the Ghaf Tree reimagined in three dimensions, suspended overhead. Naturalistic branch silhouette in bright timeless gold; crystal beads like ice glinting on winter branches. <em>Sculpture even when the lights are off.</em> Same Emirates symbol, lifted from a wall decal to architecture the customer walks beneath. <em class="mc-compare-note">(Reference image shown: ECD project featuring a comparable sculptural ceiling moment. Dedicated render pending.)</em></p>
        </div>
      </div>

      {/* Comparison 2 — Bright LED → warm dim refined retail */}
      <div class="mc-compare reveal">
        <div class="mc-compare-side">
          <span class="mc-compare-tag">Currently</span>
          <Image src={dubaiOverview} alt="Bright LED-lit Dubai floor with white surfaces" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Bright LED downlighting throughout. High lumens. Even, clinical brightness &mdash; the lighting of a phone store.</p>
        </div>
        <div class="mc-compare-arrow" aria-hidden="true">&#10142;</div>
        <div class="mc-compare-side">
          <span class="mc-compare-tag mc-compare-tag-our">Our Manhattan Evolution</span>
          <Image src={ourBathDarkStone} alt="Moody dark stone interior with brass tapware and warm spot lighting" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption"><strong>Dimmer, warmer, layered.</strong> Soft cove washes. Warm spot lighting on the key surfaces. The room feels like a five-star hotel suite, not a retail floor. The customer is bathed in flattering light &mdash; the same light that flatters them in First Class.</p>
        </div>
      </div>

      {/* Comparison 3 — bright white curved → curved + limewashed plaster */}
      <div class="mc-compare reveal">
        <div class="mc-compare-side">
          <span class="mc-compare-tag">Currently</span>
          <Image src={dubaiReception} alt="Bright white curved reception pod" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Bright white curved reception forms. Modern, clean, slightly clinical. The geometry works &mdash; the finish is generic.</p>
        </div>
        <div class="mc-compare-arrow" aria-hidden="true">&#10142;</div>
        <div class="mc-compare-side">
          <span class="mc-compare-tag mc-compare-tag-our">Our Manhattan Evolution</span>
          <Image src={ourDrywallCove} alt="Hand-finished curved limewashed walls with integrated cove lighting and walnut paneling" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Same curved geometry. <strong>Hand-troweled limewashed plaster</strong> in place of paint. References New York pre-war architecture. The curve has texture, depth, history. You can feel that someone made it by hand.</p>
        </div>
      </div>

      {/* Comparison 4 — modern furniture → club refinement, walnut + leather + brass */}
      <div class="mc-compare reveal">
        <div class="mc-compare-side">
          <span class="mc-compare-tag">Currently</span>
          <Image src={dubaiFloorWide} alt="Light modern furniture in beige and red on blonde oak" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Light modern furniture &mdash; tan upholstery, red accents, blonde wood. Pleasant. Forgettable.</p>
        </div>
        <div class="mc-compare-arrow" aria-hidden="true">&#10142;</div>
        <div class="mc-compare-side">
          <span class="mc-compare-tag mc-compare-tag-our">Our Manhattan Evolution</span>
          <Image src={ourLibraryClub} alt="Refined club library with walnut paneling, leather chairs, brass accents" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Walnut paneling. Chestnut leather. Bouclé. Brass-edged tables. <strong>The room feels like a private members&rsquo; club</strong>, not a storefront. Emirates red retained as a single signature chair per zone &mdash; the brand accent, not the dominant note.</p>
        </div>
      </div>

      {/* Comparison 5 — generic greenery → architectural botanical (olive tree welcome) */}
      <div class="mc-compare reveal">
        <div class="mc-compare-side">
          <span class="mc-compare-tag">Currently</span>
          <Image src={dubaiDisplayNiche} alt="Generic potted greenery in white planters" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption">Potted greenery in white planters &mdash; a finishing touch. Decorative, not architectural.</p>
        </div>
        <div class="mc-compare-arrow" aria-hidden="true">&#10142;</div>
        <div class="mc-compare-side">
          <span class="mc-compare-tag mc-compare-tag-our">Our Manhattan Evolution</span>
          <Image src={ourStorefrontBoutique} alt="Luxury boutique interior with mature olive tree, walnut shelving, terracotta wall" widths={[600, 900]} sizes="(min-width: 900px) 45vw, 100vw" loading="lazy" />
          <p class="mc-compare-caption"><strong>A signature mature olive tree at the welcome moment.</strong> Terrariums under glass. Moss walls. Brass-edged planters throughout. The greenery becomes architectural language, not afterthought decor. Nature is a primary material, the same weight as the brass and the leather.</p>
        </div>
      </div>

      <p class="mc-evolution-coda reveal">
        Five comparisons. Five elevations. <em>Same Emirates soul, more
        Manhattan body.</em>
      </p>
    </div>
  </section>

  {/* THE MATERIAL STORY — editorial mood board */}
  <section class="section mc-material-story">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter III</span>
        <h2 class="display display-italic mc-section-headline">
          The material story.
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          Mood board: the textures, finishes, and detail moments that build
          the Manhattan room. Every choice rewards the closer look. The
          customer can stand a foot from any surface and find craft.
        </p>
      </div>

      <div class="mc-material-grid reveal">
        <figure class="mc-material-item">
          <Image src={ourBathMarbleBrass} alt="Bookmatched Calacatta marble with polished gold tapware" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Stone &amp; gold.</strong> Bookmatched Calacatta. Solid polished gold &mdash; bright, classic, timeless, no aging. The duo that signals museum-grade craft to anyone who knows.
          </figcaption>
        </figure>
        <figure class="mc-material-item">
          <Image src={realBathVaultedRustic} alt="Reclaimed wood ceiling beams in a warm classic interior" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Architectural texture.</strong> Reclaimed wood ceiling beams. Hand-carved stone surrounds. Classic finishes with depth and warmth &mdash; timeless, never industrial.
          </figcaption>
        </figure>
        <figure class="mc-material-item">
          <Image src={ourCafeWalnut} alt="Warm cafe interior with walnut walls and copper pendant lighting" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Warm timber.</strong> Walnut. Copper pendants. The NY corner-cafe lighting register, applied to a luxury retail register. Familiar warmth, lifted by precision.
          </figcaption>
        </figure>
        <figure class="mc-material-item">
          <Image src={ourLibraryReading} alt="Coffered library reading room with leather seating and natural light" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Coffered ceiling moment.</strong> A formal architectural ceiling reference for the itinerary lounge. The detail that tells a customer they are in a serious room.
          </figcaption>
        </figure>
        <figure class="mc-material-item">
          <Image src={ourExecutiveLeather} alt="Refined executive office with leather chairs and warm dim ambient lighting" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Leather + dim.</strong> The exact lighting + materials register for the consultation pods. A meeting that feels like a conversation, not a transaction.
          </figcaption>
        </figure>
        <figure class="mc-material-item">
          <Image src={ourLightingPendant} alt="Sculptural brass pendant cluster with hand-blown glass" widths={[600, 900]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
          <figcaption>
            <strong>Sculpted brass overhead.</strong> The lighting register for the Ghaf Tree centerpiece &mdash; sculpted brass and hand-blown glass, dimensional, three-dimensional, the room's anchor.
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  {/* THE PALETTE */}
  <section class="section mc-palette">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter IV</span>
        <h2 class="display display-italic mc-section-headline">
          Palette &mdash; <em>light, gold, deep accent.</em>
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          Cream and warm white as the base &mdash; light, like the existing
          Emirates rooms. Gold as the precious metal across hardware,
          fixtures, and the signature tree-branch chandelier. The brand red,
          used sparingly as accent. Deep navy and oxblood for the upholstery
          and select walls &mdash; the &ldquo;grunge&rdquo; that grounds the
          luxury and keeps it from feeling sterile.
        </p>
      </div>

      <ul class="mc-swatches reveal" aria-label="Color palette">
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#F5F2EC"></span><span class="mc-swatch-label">Cream Base</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#FFFFFF"></span><span class="mc-swatch-label">Warm White</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#C9A961"></span><span class="mc-swatch-label">Signature Gold</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#C0392B"></span><span class="mc-swatch-label">Emirates Red (accent)</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#0F2A44"></span><span class="mc-swatch-label">Manhattan Navy</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#5C2018"></span><span class="mc-swatch-label">Oxblood Accent</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#3A2B1E"></span><span class="mc-swatch-label">Walnut</span></li>
        <li class="mc-swatch"><span class="mc-swatch-chip" style="background:#2A2A2A"></span><span class="mc-swatch-label">Blackened Steel</span></li>
      </ul>
    </div>
  </section>

  {/* MATERIALS */}
  <section class="section mc-materials">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter V</span>
        <h2 class="display display-italic mc-section-headline">
          Materials &amp; finishes.
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          Every surface chosen for the same reason: a sensory upgrade that
          makes the customer feel they are inside a private cabin.
        </p>
      </div>

      <dl class="mc-mat-list reveal">
        <div class="mc-mat-row">
          <dt>Walls</dt>
          <dd>Hand-troweled limewashed plaster in warm cream and oxblood accent panels. Selective reeded walnut paneling echoing the Emirates DNA but in deeper tone.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Floors</dt>
          <dd>Reclaimed plank flooring in warm walnut tones over a polished travertine base in transitional zones. Brass inlay strips at thresholds.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Ceiling</dt>
          <dd>Flush plaster with integrated cove lighting around the perimeter. The signature polished-gold tree-branch chandelier with hand-strung crystal accents as the central architectural moment &mdash; a naturalistic branch silhouette suspended overhead, ~7 to 9 feet across, scaled to the room. Sculpture by day, light source by evening. Bright timeless gold finish &mdash; classic, never aged.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Lighting</dt>
          <dd>Layered: warm dimmable spot lighting on key surfaces, cove washes, and the gold tree-branch chandelier as the room&rsquo;s anchor. No bright LED. Closer to incandescent warmth.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Upholstery</dt>
          <dd>Deep chestnut leather, ivory bouclé, navy mohair. Emirates red retained as a single signature accent chair per zone.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Hardware</dt>
          <dd>Polished solid gold throughout &mdash; bright, timeless, classic. The Emirates wordmark color, matched. No aging, no patina &mdash; the same finish on day one as in year ten. Blackened steel reserved for minimal Apple-store precision moments where contrast serves the design.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Botanical</dt>
          <dd>A signature mature olive tree at the entry. Terrariums under glass. Selected moss walls. Brass-edged planters throughout.</dd>
        </div>
        <div class="mc-mat-row">
          <dt>Sensory</dt>
          <dd>A bespoke ambient scent in the room. A curated low soundscape. Both calibrated to the time of day.</dd>
        </div>
      </dl>
    </div>
  </section>

  {/* THE SHOWCASE — experience zones */}
  <section class="section mc-showcase">
    <div class="container">
      <div class="mc-section-header reveal">
        <span class="eyebrow">Chapter VI</span>
        <h2 class="display display-italic mc-section-headline">
          The showcase &mdash; <em>did I choose right?</em>
        </h2>
        <GoldRule width="64px" />
        <p class="mc-section-lead">
          People are not paying for a plane ticket. They are paying for an
          experience. The Manhattan store&rsquo;s most important job is to
          make every visitor walk out certain they chose the right airline.
          We design dedicated zones for that &mdash; tactile, edible,
