  {/* GATE SCRIPT */}
  <script is:inline define:vars={{ HASH: PASSWORD_HASH }}>
    (function () {
      const SESSION_KEY = 'ecd_mc_unlocked_' + HASH.slice(0, 12);
      try {
        const stale = [];
        for (let i = 0; i < sessionStorage.length; i++) {
          const k = sessionStorage.key(i);
          if (k && k.startsWith('ecd_mc_unlocked') && k !== SESSION_KEY) stale.push(k);
        }
        stale.forEach((k) => sessionStorage.removeItem(k));
      } catch (e) {}

      const gate = document.getElementById('mc-gate');
      const content = document.getElementById('mc-content');
      const form = document.getElementById('mc-gate-form');
      const input = document.getElementById('mc-gate-input');
      const errorEl = document.getElementById('mc-gate-error');

      function unlock() {
        if (gate) gate.style.display = 'none';
        if (content) content.style.display = '';
        document.body.style.overflow = '';
      }
      function lock() {
        if (gate) gate.style.display = '';
        if (content) content.style.display = 'none';
        document.body.style.overflow = 'hidden';
        if (input) setTimeout(() => input.focus(), 30);
      }

      if (sessionStorage.getItem(SESSION_KEY) === '1') unlock();
      else lock();

      async function sha256(str) {
        const buf = new TextEncoder().encode(str);
        const hash = await crypto.subtle.digest('SHA-256', buf);
        return Array.from(new Uint8Array(hash))
          .map((b) => b.toString(16).padStart(2, '0'))
          .join('');
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorEl.hidden = true;
          const val = input.value.trim();
          if (!val) return;
          try {
            const h = await sha256(val);
            if (h === HASH) {
              sessionStorage.setItem(SESSION_KEY, '1');
              unlock();
            } else {
              errorEl.hidden = false;
              input.value = '';
              input.focus();
            }
          } catch (err) {
            errorEl.hidden = false;
          }
        });
      }
    })();
  </script>

  {/* AUDIO NARRATION (Web Speech API) */}
  <script is:inline>
    (function () {
      const btn = document.getElementById('mc-listen');
      const status = document.getElementById('mc-listen-status');
      if (!btn || !('speechSynthesis' in window)) {
        if (btn) btn.style.display = 'none';
        return;
      }

      const NARRATION = [
        "Welcome. This is the concept for the Manhattan Emirates World travel store, by East Coast Designers.",
        "This proposal is built around one design intent: a private jet sensibility, brought downstairs and made accessible.",
        "Emirates is showcased as a luxury airline, and most customers walking into this store will never fly private. The closest experience they will ever have to private aviation is the moment they walk through this door. The store IS the cabin upgrade. Our job is to make every material, every light, every chair, every detail feel like the customer is what's being showcased.",
        "Emirates already created the design DNA. The Ghaf Tree. The light curved forms. The vertical wood slat walls. The greenery as architecture. That works. Our job is not to override it. Our job is to translate it into a Manhattan vernacular without losing what makes it Emirates.",
        "What we add: deeper materials. Hand troweled limewashed walls referencing pre war New York. A signature tree branch chandelier, sculpted in gold, replacing the wall mounted tree light. Dimmer, warmer spot lighting in place of bright L E D. Reclaimed plank floors over blonde oak. Leather, bouclé, brass edged planters, terrariums under glass. A scent. A soundscape. The complete sensory upgrade.",
        "We also design dedicated showcase zones for the customer. A Cabin Test where they sit in an actual Business Class seat. A Tasting Bar with the food served onboard. A Brand Wall telling the Emirates story since nineteen eighty five. A floor to ceiling Sky Window with live aerial footage from Emirates routes. Private itinerary lounges instead of a counter. A Why-Emirates letterpress card every visitor takes home. Every detail in service of one feeling: I chose the right airline.",
        "The team is two women, design and construction veterans from this area, on our farewell project to the tri state. We are honest about that, because trust beats convenience. You get our undivided focus.",
        "We are ready to translate your global design language for Manhattan, and to travel for the next city after that. We will deliver this with the soul of two people who actually love what they do.",
        "The soul of a place that needed to be captured and spread and continue its legacy. Because it's that beautiful.",
        "Thank you. We hope to hear from you soon."
      ];

      let queue = [];
      let playing = false;
      let paused = false;

      function pickVoice() {
        const voices = speechSynthesis.getVoices();
        if (!voices.length) return null;
        const preferred = [
          'Samantha', 'Karen', 'Victoria', 'Allison', 'Ava',
          'Google US English', 'Google UK English Female',
          'Microsoft Aria', 'Microsoft Zira', 'Microsoft Jenny',
        ];
        for (const name of preferred) {
          const v = voices.find((v) => v.name.includes(name));
          if (v) return v;
        }
        const enFemale = voices.find(
          (v) => v.lang.startsWith('en') && /female|woman|she/i.test(v.name)
        );
        if (enFemale) return enFemale;
        return voices.find((v) => v.lang.startsWith('en')) || voices[0];
      }

      function setStatus(msg) {
        if (status) status.textContent = msg;
      }

      function speakNext() {
        if (!queue.length) {
          playing = false;
          btn.classList.remove('is-playing');
          btn.querySelector('.mc-listen-icon').innerHTML = '&#9654;';
          btn.querySelector('.mc-listen-text').textContent = 'Listen to the pitch';
          setStatus('');
          return;
        }
        const text = queue.shift();
        const u = new SpeechSynthesisUtterance(text);
        const v = pickVoice();
        if (v) u.voice = v;
        u.rate = 0.92;
        u.pitch = 1.05;
        u.volume = 1.0;
        u.onend = () => {
          if (playing && !paused) speakNext();
        };
        u.onerror = () => {
          playing = false;
          btn.classList.remove('is-playing');
          setStatus('Audio unavailable. Please use Chrome, Safari, or Edge.');
        };
        speechSynthesis.speak(u);
      }

      function play() {
        speechSynthesis.cancel();
        queue = NARRATION.slice();
        playing = true;
        paused = false;
        btn.classList.add('is-playing');
        btn.querySelector('.mc-listen-icon').innerHTML = '&#10074;&#10074;';
        btn.querySelector('.mc-listen-text').textContent = 'Pause narration';
        setStatus('Narration playing...');
        speakNext();
      }

      function pause() {
        speechSynthesis.cancel();
        playing = false;
        paused = true;
        btn.classList.remove('is-playing');
        btn.querySelector('.mc-listen-icon').innerHTML = '&#9654;';
        btn.querySelector('.mc-listen-text').textContent = 'Resume narration';
        setStatus('Narration paused.');
      }

      btn.addEventListener('click', () => {
        if (playing) {
          pause();
        } else {
          play();
        }
      });

      if (speechSynthesis.getVoices().length === 0) {
        speechSynthesis.addEventListener('voiceschanged', () => {
          // voices now available; future click will work
        });
      }
    })();
  </script>

  {/* REVEAL ANIMATION */}
  <script is:inline>
    const mcReveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && mcReveals.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      mcReveals.forEach((el) => observer.observe(el));
    } else {
      mcReveals.forEach((el) => el.classList.add('is-visible'));
    }
  </script>

