---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLink from '../components/PhoneLink.astro';
import TextLink from '../components/TextLink.astro';
import GoldRule from '../components/GoldRule.astro';

import commercialLobbyMarble from '../assets/images/commercial-lobby-marble.jpg';
import hospitalityArtLobby from '../assets/images/hospitality-art-lobby.jpg';
import hospitalityLounge from '../assets/images/hospitality-lounge.jpg';
import commercialReceptionWood from '../assets/images/commercial-reception-wood.jpg';
import kitchenMarble from '../assets/images/kitchen-marble.jpg';
import bathMarble from '../assets/images/bath-marble.jpg';
import livingWarm from '../assets/images/living-warm.jpg';
import livingFireplace from '../assets/images/living-fireplace.jpg';
import diningElegant from '../assets/images/dining-elegant.jpg';
import heroLiving from '../assets/images/hero-living.jpg';
import exteriorTraditional from '../assets/images/exterior-traditional.jpg';

const heroPhotos = [
  { src: commercialLobbyMarble, alt: 'Commercial lobby interior' },
  { src: hospitalityArtLobby, alt: 'Hospitality atrium' },
  { src: kitchenMarble, alt: 'Kitchen renovation' },
  { src: hospitalityLounge, alt: 'Hospitality lounge' },
];

const midbandPhotos = [
  { src: heroLiving, alt: 'Residential interior' },
  { src: bathMarble, alt: 'Bathroom design' },
  { src: livingFireplace, alt: 'Living room' },
  { src: diningElegant, alt: 'Dining room' },
];

const title = 'Design + Build | East Coast Designers';
const description = 'East Coast Designers is a design and construction practice — full interior design, 2D and 3D renderings, and ground-up construction. Residential and commercial. Based in Connecticut, working tri-state and select projects nationwide.';
---
<BaseLayout title={title} description={description}>

  <section class="hero">
    <div class="hero-photos" data-photo-rotator>
      {heroPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
          class={`hero-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <div class="hero-text-panel">
        <span class="eyebrow hero-eyebrow">Design + Build</span>
        <h1>Design and construction,<br/>under one roof.</h1>
        <GoldRule width="64px" />
        <p class="hero-subhead">
          Interior design, renderings, and ground-up construction. Residential and commercial.
          Based in Connecticut, working tri-state and select projects nationwide.
        </p>
        <div class="hero-cta-row">
          <PhoneLink class="btn btn-primary hero-cta" prefix="Call " />
          <TextLink class="btn btn-ghost hero-cta-ghost" label="Request a consultation" />
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-photo-rotator]').forEach((rotator) => {
      const photos = Array.from(rotator.querySelectorAll('.rotator-photo'));
      if (photos.length < 2) return;
      let current = 0;
      setInterval(() => {
        photos[current].classList.remove('is-active');
        current = (current + 1) % photos.length;
        photos[current].classList.add('is-active');
      }, 6000);
    });
  </script>

  <section class="metadata-strip" aria-label="Practice at a glance">
    <div class="container">
      <ul class="metadata-list">
        <li><span class="metadata-num">01</span><span class="metadata-text">Based in Connecticut</span></li>
        <li><span class="metadata-num">02</span><span class="metadata-text">Tri-state &amp; Nationwide</span></li>
        <li><span class="metadata-num">03</span><span class="metadata-text">Residential &amp; Commercial</span></li>
        <li><span class="metadata-num">04</span><span class="metadata-text">Designer &amp; General Contractor</span></li>
      </ul>
    </div>
  </section>

  <section class="section bio-section">
    <div class="container content">
      <span class="eyebrow">East Coast Designers</span>
      <h2 class="bio-headline">A full-service design and construction firm,<br/>founded and led by a contractor and designer.</h2>
      <GoldRule width="64px" />
      <p class="bio-lede">
        East Coast Designers is a design and construction practice that handles every stage
        of a project, from the first rendering through the final punch list. Founded by
        Cristina — a contractor and interior designer who grew up in the trade — the
        practice brings design and construction under one roof.
      </p>
      <p class="bio-body">
        We work on residential and commercial projects: full interior design, 2D and 3D
        renderings, finish and material sourcing, additions, renovations, and ground-up
        construction. The work is simple, classic, and timeless — built to make a house
        feel like a home, and to make a commercial space feel right for the people who
        use it. Based in Connecticut. We work the tri-state area regularly and take on
        select projects nationwide.
      </p>
      <p class="bio-body bio-team">
        Owner-operated. Cristina leads every project as designer and general contractor,
        working with a vetted network of trusted trade partners — and collaborating with
        other designers, architects, and GCs when scope requires. The result is one
        point of contact, one accountable lead, and a single team that handles design,
        coordination, and build from start to finish.
      </p>
    </div>
  </section>

  <section class="section practice-section">
    <div class="container">
      <div class="practice-header">
        <span class="eyebrow">Practice</span>
        <h2>Four pillars. One accountable lead.</h2>
        <GoldRule width="64px" />
      </div>
      <ol class="practice-list">
        <li class="practice-item">
          <span class="practice-num">01</span>
          <div class="practice-body">
            <h3>Design</h3>
            <p>Full interior design, 2D and 3D renderings, finish and material selection, furniture and fixtures sourcing.</p>
          </div>
        </li>
        <li class="practice-item">
          <span class="practice-num">02</span>
          <div class="practice-body">
            <h3>Build</h3>
            <p>Additions, ground-up new construction, whole-home renovations, commercial buildouts. Residential and commercial.</p>
          </div>
        </li>
        <li class="practice-item">
          <span class="practice-num">03</span>
          <div class="practice-body">
            <h3>Delivery</h3>
            <p>One accountable lead from concept through punch list. Single point of contact. Trade partners coordinated end to end.</p>
          </div>
        </li>
        <li class="practice-item">
          <span class="practice-num">04</span>
          <div class="practice-body">
            <h3>Collaboration</h3>
            <p>Joint engagements with other designers, architects, and GCs when scope or schedule benefits from a wider team.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="midband-rotator" aria-label="Selected work">
    <div class="midband-photos" data-photo-rotator>
      {midbandPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading="lazy"
          class={`midband-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="midband-overlay"></div>
    <div class="midband-caption">
      <span class="eyebrow">Selected Work</span>
    </div>
  </section>

  <section class="section section-bleed-offwhite services-pair">
    <div class="container">
      <div class="pair-grid">
        <a href="/interior-design" class="pair-card">
          <div class="pair-image">
            <Image
              src={hospitalityArtLobby}
              alt="Commercial interior"
              widths={[600, 900, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="pair-body">
            <span class="eyebrow pair-eyebrow">01 — Service</span>
            <h3>Interior Design</h3>
            <p>
              Full interior design for residential and commercial. 2D and 3D renderings,
              finish and material selection, furniture and fixtures sourcing, project
              delivery from concept through install.
            </p>
            <span class="pair-link">See interior design →</span>
          </div>
        </a>

        <a href="/construction" class="pair-card">
          <div class="pair-image">
            <Image
              src={exteriorTraditional}
              alt="Residential exterior"
              widths={[600, 900, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="pair-body">
            <span class="eyebrow pair-eyebrow">02 — Service</span>
            <h3>Construction</h3>
            <p>
              Additions, ground-up new construction, whole-home renovations, and commercial
              buildouts. We build what we design.
            </p>
            <span class="pair-link">See construction →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="pullquote-band">
    <div class="container content pullquote-inner">
      <span class="pullquote-mark">&ldquo;</span>
      <p class="pullquote">
        Atmosphere is the work. A well-built room with the right proportions, the right
        light, and the right materials feels right to live in for decades.
      </p>
      <GoldRule width="56px" align="center" />
      <p class="pullquote-attribution">Simple &middot; Classic &middot; Timeless</p>
    </div>
  </section>

  <section class="section work-teaser">
    <div class="container">
      <div class="teaser-header">
        <span class="eyebrow">Work</span>
        <h2>Design and build, across a range of projects.</h2>
      </div>
      <div class="teaser-grid">
        <figure class="teaser-tile teaser-tile--tall">
          <Image
            src={bathMarble}
            alt="Bathroom renovation"
            widths={[600, 900]}
            sizes="(min-width: 960px) 33vw, 100vw"
            loading="lazy"
          />
          <figcaption>Primary bath renovation</figcaption>
        </figure>
        <figure class="teaser-tile">
          <Image
            src={livingWarm}
            alt="Living room"
            widths={[600, 900]}
            sizes="(min-width: 960px) 33vw, 100vw"
            loading="lazy"
          />
          <figcaption>Living room design</figcaption>
        </figure>
        <figure class="teaser-tile">
          <Image
            src={commercialReceptionWood}
            alt="Office reception interior"
            widths={[600, 900]}
            sizes="(min-width: 960px) 33vw, 100vw"
            loading="lazy"
          />
          <figcaption>Office Reception</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-bleed-navy closing-band">
    <div class="container content">
      <h2>Planning a project?</h2>
      <p class="closing-body">We'd be glad to come take a look. Call or send a request — we'll get back to you the same day.</p>
      <div class="closing-cta-row">
        <PhoneLink class="btn btn-primary closing-cta" prefix="Call " />
        <TextLink class="btn btn-ghost closing-cta-ghost" label="Request a consultation" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ----- HERO ----- */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-white);
  }
  .hero-photos {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-photo, .midband-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.4s ease-in-out;
  }
  .hero-photo.is-active, .midband-photo.is-active { opacity: 1; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(15,42,68,0.55) 0%, rgba(15,42,68,0.25) 60%, rgba(15,42,68,0.1) 100%);
    z-index: 1;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
  }
  .hero-text-panel {
    background-color: rgba(15, 42, 68, 0.6);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: clamp(var(--space-4), 3vw, var(--space-6));
    max-width: 480px;
    width: 100%;
  }
  @media (min-width: 1280px) {
    .hero-text-panel { max-width: 520px; padding: var(--space-6) var(--space-8); }
  }
  .hero-eyebrow { color: var(--color-gold); margin-bottom: var(--space-2); }
  .hero h1 {
    color: var(--color-white);
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
  }
  .hero-subhead {
    color: var(--color-white);
    opacity: 0.96;
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    max-width: 48ch;
    line-height: 1.55;
  }
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .hero-cta {
    background-color: var(--color-white);
    color: var(--color-navy);
    border-color: var(--color-white);
    padding: 12px 24px;
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .hero-cta:hover {
    background-color: transparent;
    color: var(--color-white);
    border-color: var(--color-gold);
  }
  .hero-cta-ghost {
    background-color: transparent;
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
    padding: 12px 24px;
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .hero-cta-ghost:hover {
    background-color: transparent;
    color: var(--color-gold);
    border-color: var(--color-gold);
  }
  @media (max-width: 720px) {
    .hero-inner { justify-content: center; }
    .hero-text-panel { padding: var(--space-4); }
  }

  /* ----- MIDBAND ROTATOR ----- */
  .midband-rotator {
    position: relative;
    min-height: 60vh;
    overflow: hidden;
    background-color: var(--color-navy);
  }
  .midband-photos {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .midband-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15,42,68,0.0) 0%, rgba(15,42,68,0.0) 70%, rgba(15,42,68,0.4) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .midband-caption {
    position: absolute;
    left: var(--gutter);
    bottom: var(--space-4);
    z-index: 2;
  }
  .midband-caption .eyebrow {
    color: var(--color-white);
    opacity: 0.9;
    margin-bottom: 0;
  }
  @media (max-width: 720px) {
    .midband-rotator { min-height: 40vh; }
  }

  /* ----- BIO ----- */
  .bio-section {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .bio-section .content { max-width: 820px; }
  .bio-headline {
    font-size: clamp(var(--text-3xl), 4.5vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    margin-bottom: var(--space-3);
    color: var(--color-navy);
  }
  .bio-lede {
    font-size: var(--text-xl);
    line-height: 1.6;
    color: var(--color-navy);
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
    font-weight: 400;
  }
  .bio-body {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-muted);
    margin: 0;
    max-width: 64ch;
  }

  /* ----- PAIR (Construction + Interior Design) ----- */
  .services-pair {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .pair-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 768px) {
    .pair-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }
  .pair-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-white);
    transition: transform 0.3s ease;
  }
  .pair-card:hover { transform: translateY(-4px); }
  .pair-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .pair-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .pair-card:hover .pair-image :global(img) { transform: scale(1.03); }
  .pair-body { padding: var(--space-4) var(--space-4) var(--space-3); }
  .pair-eyebrow { color: var(--color-gold); margin-bottom: var(--space-2); }
  .pair-body h3 {
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    margin: var(--space-2) 0;
    color: var(--color-navy);
  }
  .pair-body p {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: var(--space-3);
    max-width: 48ch;
  }
  .pair-link {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-navy);
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 2px;
  }
  .pair-card:hover .pair-link { color: var(--color-gold); }

  /* ----- PHILOSOPHY BAND ----- */
  /* ----- METADATA STRIP ----- */
  .metadata-strip {
    background-color: var(--color-white);
    border-bottom: 1px solid rgba(15, 42, 68, 0.08);
    padding: var(--space-3) 0;
  }
  .metadata-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (min-width: 768px) {
    .metadata-list {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
    }
  }
  .metadata-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: var(--label-letter-spacing);
    text-transform: uppercase;
    color: var(--color-navy);
  }
  .metadata-num {
    color: var(--color-gold);
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
  }
  .metadata-text { color: var(--color-body); font-weight: 500; }

  /* ----- PRACTICE FRAMEWORK ----- */
  .practice-section {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .practice-header { max-width: 820px; margin-bottom: var(--space-12); }
  .practice-header h2 {
    font-size: clamp(var(--text-3xl), 4.5vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    margin-bottom: var(--space-3);
    color: var(--color-navy);
  }
  .practice-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 1080px;
  }
  @media (min-width: 768px) {
    .practice-list { grid-template-columns: 1fr 1fr; gap: var(--space-8) var(--space-12); }
  }
  .practice-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(15, 42, 68, 0.06);
  }
  .practice-num {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    line-height: 1;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }
  .practice-body h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    margin-top: -0.15em;
    color: var(--color-navy);
  }
  .practice-body p {
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-body);
    margin: 0;
    max-width: 50ch;
  }

  /* ----- PULL QUOTE BAND ----- */
  .pullquote-band {
    padding-top: clamp(var(--space-16), 12vw, 8rem);
    padding-bottom: clamp(var(--space-16), 12vw, 8rem);
    background-color: var(--color-white);
  }
  .pullquote-inner {
    text-align: center;
    max-width: 820px;
  }
  .pullquote-mark {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 6rem);
    color: var(--color-gold);
    line-height: 0.6;
    margin-bottom: var(--space-3);
    opacity: 0.65;
  }
  .pullquote {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 3.6vw, 2.75rem);
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--color-navy);
    margin: 0 auto var(--space-6) auto;
    padding: 0;
    border: none;
    quotes: none;
    font-weight: 400;
    font-style: italic;
    max-width: 28ch;
  }
  .pullquote-attribution {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: var(--space-2) 0 0 0;
  }

  .philosophy-band {
    padding-top: clamp(var(--space-16), 12vw, 8rem);
    padding-bottom: clamp(var(--space-16), 12vw, 8rem);
    background-color: var(--color-white);
  }
  .philosophy-inner { text-align: center; max-width: 720px; }
  .philosophy-mark {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-4xl), 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    margin: var(--space-3) 0;
    font-style: italic;
    font-weight: 400;
  }
  .philosophy-body {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.7;
    margin-top: var(--space-4);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ----- WORK TEASER ----- */
  .work-teaser {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
    background-color: var(--color-offwhite);
  }
  .teaser-header {
    margin-bottom: var(--space-8);
