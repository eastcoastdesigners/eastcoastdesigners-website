---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLink from '../components/PhoneLink.astro';
import TextLink from '../components/TextLink.astro';
import GoldRule from '../components/GoldRule.astro';

import commercialOffice from '../assets/images/commercial-office.jpg';
import commercialBoutiqueLight from '../assets/images/commercial-boutique-light.jpg';
import commercialBoardroomModern from '../assets/images/commercial-boardroom-modern.jpg';
import commercialExecutiveLeather from '../assets/images/commercial-executive-leather.jpg';
import commercialLibraryClub from '../assets/images/commercial-library-club.jpg';
import commercialLoungeLeather from '../assets/images/commercial-lounge-leather.jpg';
import commercialExecutiveLounge from '../assets/images/commercial-executive-lounge.jpg';
import commercialLibraryReading from '../assets/images/commercial-library-reading.jpg';
import commercialBarNavy from '../assets/images/commercial-bar-navy.jpg';
import commercialCafeWalnut from '../assets/images/commercial-cafe-walnut.jpg';
import commercialDiningDeco from '../assets/images/commercial-dining-deco.jpg';

import hospitalityArtLobby from '../assets/images/hospitality-art-lobby.jpg';
import hospitalityHotelLobby from '../assets/images/hospitality-hotel-lobby.jpg';
import hospitalityLounge from '../assets/images/hospitality-lounge.jpg';
import hospitalityRestaurantBrass from '../assets/images/hospitality-restaurant-brass.jpg';
import hospitalityRestaurantChandelier from '../assets/images/hospitality-restaurant-chandelier.jpg';
import hospitalityRestaurantCopper from '../assets/images/hospitality-restaurant-copper.jpg';
import hospitalityRestaurantWood from '../assets/images/hospitality-restaurant-wood.jpg';

import kitchenMarble from '../assets/images/kitchen-marble.jpg';
import kitchenHero from '../assets/images/kitchen-hero.jpg';
import bathMarble from '../assets/images/bath-marble.jpg';
import bathModern from '../assets/images/bath-modern.jpg';
import livingFireplace from '../assets/images/living-fireplace.jpg';
import livingWarm from '../assets/images/living-warm.jpg';
import diningElegant from '../assets/images/dining-elegant.jpg';
import diningChandelier from '../assets/images/dining-chandelier.jpg';
import heroLiving from '../assets/images/hero-living.jpg';
import exteriorModern from '../assets/images/exterior-modern.jpg';
import exteriorTraditional from '../assets/images/exterior-traditional.jpg';

const heroPhotos = [
  { src: commercialBoardroomModern, alt: 'Modern boardroom interior' },
  { src: commercialLibraryClub, alt: 'Wood-paneled library and reception' },
  { src: commercialBoutiqueLight, alt: 'Boutique retail interior with editorial styling' },
  { src: kitchenMarble, alt: 'Residential kitchen' },
  { src: commercialBarNavy, alt: 'Commercial bar with marble and brass' },
  { src: hospitalityLounge, alt: 'Hospitality lounge' },
  { src: commercialDiningDeco, alt: 'Private dining room with Art Deco chandelier' },
];

const residentialPhotos = [
  { src: kitchenMarble, alt: 'Marble kitchen' },
  { src: livingFireplace, alt: 'Living room with fireplace' },
  { src: bathMarble, alt: 'Marble bathroom' },
  { src: diningChandelier, alt: 'Dining room' },
  { src: kitchenHero, alt: 'Kitchen interior' },
];

const commercialPhotos = [
  { src: commercialBoardroomModern, alt: 'Modern boardroom interior' },
  { src: commercialLibraryClub, alt: 'Wood-paneled library and reception' },
  { src: commercialExecutiveLounge, alt: 'Executive lounge with chandelier' },
  { src: commercialBarNavy, alt: 'Commercial bar with marble counter and brass' },
  { src: commercialDiningDeco, alt: 'Private dining room with Art Deco chandelier' },
  { src: commercialCafeWalnut, alt: 'Commercial cafe with walnut and marble' },
  { src: commercialExecutiveLeather, alt: 'Executive office with leather chairs' },
  { src: commercialLibraryReading, alt: 'Coffered-ceiling library reading room' },
  { src: commercialOffice, alt: 'Modern office interior' },
  { src: commercialLoungeLeather, alt: 'Dark leather lounge with stained glass' },
  { src: commercialBoutiqueLight, alt: 'Boutique retail interior' },
];

const hospitalityPhotos = [
  { src: hospitalityHotelLobby, alt: 'Hotel lobby' },
  { src: hospitalityRestaurantChandelier, alt: 'Restaurant with crystal chandelier' },
  { src: hospitalityLounge, alt: 'Hospitality lounge' },
  { src: hospitalityRestaurantBrass, alt: 'Restaurant with brass detailing' },
  { src: hospitalityRestaurantWood, alt: 'Wood-paneled restaurant' },
  { src: hospitalityRestaurantCopper, alt: 'Bar with copper-top tables' },
];

const capabilities = [
  'Full Interior Design',
  '2D + 3D Renderings',
  'Finish & Material Selection',
  'Custom Cabinetry',
  'Additions',
  'Whole-Home Renovations',
  'New Construction',
  'Commercial Buildouts',
  'Hospitality Design',
  'Furniture & Fixtures',
  'Lighting Design',
  'Project Delivery',
];

const title = 'Design + Build | East Coast Designers';
const description = 'East Coast Designers is a design and construction practice — full interior design, 2D and 3D renderings, and ground-up construction. Residential, commercial, and hospitality. Based in Connecticut, working tri-state and select projects nationwide.';
---
<BaseLayout title={title} description={description}>

  <section class="hero">
    <div class="hero-photos" data-photo-rotator>
      {heroPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
          class={`hero-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="hero-vignette"></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow hero-eyebrow">East Coast Designers &mdash; Est. Connecticut</span>
        <h1 class="display display-italic hero-headline">
          Design and construction,<br/><em>under one roof.</em>
        </h1>
        <GoldRule width="80px" />
        <p class="hero-subhead">
          Interior design, renderings, and ground-up construction. Residential, commercial,
          and hospitality. Based in Connecticut, working tri-state and select projects nationwide.
        </p>
        <div class="hero-cta-row">
          <PhoneLink class="btn btn-primary hero-cta" prefix="Call " />
          <TextLink class="btn btn-ghost hero-cta-ghost" label="Request a consultation" />
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator" aria-hidden="true">
      <span class="hero-scroll-label">Scroll</span>
      <span class="hero-scroll-line"></span>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-photo-rotator]').forEach((rotator) => {
      const photos = Array.from(rotator.querySelectorAll('.rotator-photo'));
      if (photos.length < 2) return;
      let current = 0;
      setInterval(() => {
        photos[current].classList.remove('is-active');
        current = (current + 1) % photos.length;
        photos[current].classList.add('is-active');
      }, 5500);
    });

    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && reveals.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach((el) => observer.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('is-visible'));
    }
  </script>

  <section class="metadata-strip" aria-label="Practice at a glance">
    <div class="container">
      <ul class="metadata-list">
        <li><span class="metadata-num">I</span><span class="metadata-text">Based in Connecticut</span></li>
        <li><span class="metadata-num">II</span><span class="metadata-text">Tri-state &amp; Nationwide</span></li>
        <li><span class="metadata-num">III</span><span class="metadata-text">Residential, Commercial &amp; Hospitality</span></li>
        <li><span class="metadata-num">IV</span><span class="metadata-text">Designer &amp; General Contractor</span></li>
      </ul>
    </div>
  </section>

  <section class="bio-section">
    <Image
      src={heroLiving}
      alt="Residential interior"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="lazy"
      class="bio-bg-photo"
    />
    <div class="bio-overlay"></div>
    <div class="container bio-inner">
      <div class="bio-content reveal">
        <span class="eyebrow">The Practice</span>
        <h2 class="display display-italic bio-headline">
          A design and construction firm,<br/>
          founded and led by a <em>contractor and designer</em>.
        </h2>
        <GoldRule width="80px" />
        <p class="bio-lede">
          East Coast Designers handles every stage of a project &mdash; from the first
          rendering through the final punch list.
        </p>
        <p class="bio-body">
          Founded by Cristina, a contractor and interior designer who grew up in the
          trade, the practice brings design and construction under one roof. Residential,
          commercial, and hospitality. Full interior design, 2D and 3D renderings, finish
          and material sourcing, additions, renovations, and ground-up construction.
        </p>
        <p class="bio-body bio-team">
          Owner-operated. Cristina leads every project as designer and general contractor,
          working with a vetted network of trade partners &mdash; and collaborating with
          other designers, architects, and GCs when scope requires. One point of contact,
          one accountable lead, from start to finish.
        </p>
      </div>
    </div>
  </section>

  <section class="capabilities-marquee" aria-label="Capabilities">
    <div class="marquee-track" aria-hidden="true">
      {[...capabilities, ...capabilities].map((cap) => (
        <span class="marquee-item">
          <span class="marquee-text">{cap}</span>
          <span class="marquee-dot">&#x2022;</span>
        </span>
      ))}
    </div>
    <span class="sr-only">Capabilities: {capabilities.join(', ')}.</span>
  </section>

  <section class="section practice-section practice-section--dark">
    <div class="container">
      <div class="practice-header reveal">
        <span class="eyebrow">Practice</span>
        <h2 class="display display-italic">Four pillars.<br/><em>One accountable lead.</em></h2>
        <GoldRule width="80px" />
      </div>
      <ol class="practice-list">
        <li class="practice-item reveal">
          <span class="practice-num">01</span>
          <div class="practice-body">
            <h3>Design</h3>
            <p>Full interior design, 2D and 3D renderings, finish and material selection, furniture and fixtures sourcing.</p>
          </div>
        </li>
        <li class="practice-item reveal">
          <span class="practice-num">02</span>
          <div class="practice-body">
            <h3>Build</h3>
            <p>Additions, ground-up new construction, whole-home renovations, commercial buildouts. Residential, commercial, and hospitality.</p>
          </div>
        </li>
        <li class="practice-item reveal">
          <span class="practice-num">03</span>
          <div class="practice-body">
            <h3>Delivery</h3>
            <p>One accountable lead from concept through punch list. Single point of contact. Trade partners coordinated end to end.</p>
          </div>
        </li>
        <li class="practice-item reveal">
          <span class="practice-num">04</span>
          <div class="practice-body">
            <h3>Collaboration</h3>
            <p>Joint engagements with other designers, architects, and GCs when scope or schedule benefits from a wider team.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="section process-section">
    <div class="container">
      <div class="process-header reveal">
        <span class="eyebrow">Process</span>
        <h2 class="display display-italic">How we work,<br/>from <em>first conversation</em> to <em>final walk-through</em>.</h2>
        <GoldRule width="80px" />
      </div>
      <ol class="process-list">
        <li class="process-item reveal">
          <span class="process-num">01</span>
          <div class="process-body">
            <h3>Discovery &amp; Brief</h3>
            <p>A guided intake &mdash; questionnaire, site visit, conversation. We listen for what the space needs to do, who uses it, and what the project has to feel like when it's done.</p>
          </div>
        </li>
        <li class="process-item reveal">
          <span class="process-num">02</span>
          <div class="process-body">
            <h3>Design Development</h3>
            <p>2D plans, layouts, and concept boards. Material direction. We agree on the plan in writing before any work begins.</p>
          </div>
        </li>
        <li class="process-item reveal">
          <span class="process-num">03</span>
          <div class="process-body">
            <h3>Renderings</h3>
            <p>3D visualization of the finished space &mdash; so you see what you're approving, not just a floor plan.</p>
          </div>
        </li>
        <li class="process-item reveal">
          <span class="process-num">04</span>
          <div class="process-body">
            <h3>Sourcing</h3>
            <p>Finishes, fixtures, furniture, and materials specified and procured. Everything documented, every selection signed off.</p>
          </div>
        </li>
        <li class="process-item reveal">
          <span class="process-num">05</span>
          <div class="process-body">
            <h3>Build &amp; Install</h3>
            <p>Construction, coordination, install, punch list. One accountable lead from demo through hand-off. Day and night when the schedule requires.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="sectors-intro">
    <div class="container reveal">
      <span class="eyebrow">Sectors</span>
      <h2 class="display display-italic sectors-intro-headline">
        Three sectors.<br/><em>One standard of craft.</em>
      </h2>
      <GoldRule width="80px" />
      <p class="sectors-intro-body">
        The practice works across residential, commercial, and hospitality. Different briefs,
        different constraints &mdash; the same eye for proportion, the same delivery discipline.
      </p>
    </div>
  </section>

  <section class="sector-band sector-band--left">
    <div class="sector-photos" data-photo-rotator>
      {residentialPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading="lazy"
          class={`sector-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="sector-overlay"></div>
    <div class="container sector-inner">
      <div class="sector-text reveal">
        <span class="sector-numeral">I</span>
        <span class="eyebrow sector-eyebrow">Sector</span>
        <h3 class="display display-italic sector-headline"><em>Residential</em></h3>
        <p class="sector-body">
          Kitchens and baths designed to the millimeter. Whole-home renovations,
          additions, and ground-up new construction. Spaces built to make a house feel
          like a home &mdash; and to hold up for decades.
        </p>
        <ul class="sector-list">
          <li>Kitchens</li>
          <li>Bathrooms</li>
          <li>Whole-Home Renovations</li>
          <li>Additions</li>
          <li>New Construction</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="sector-band sector-band--right">
    <div class="sector-photos" data-photo-rotator>
      {commercialPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading="lazy"
          class={`sector-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="sector-overlay sector-overlay--right"></div>
    <div class="container sector-inner sector-inner--right">
      <div class="sector-text reveal">
        <span class="sector-numeral">II</span>
        <span class="eyebrow sector-eyebrow">Sector</span>
        <h3 class="display display-italic sector-headline"><em>Commercial</em></h3>
        <p class="sector-body">
          Executive offices, boardrooms, reception, lobbies, boutique retail. Commercial
          spaces that look the part of the business they house &mdash; built on schedule,
          to spec, with day-and-night crews when the build requires it.
        </p>
        <ul class="sector-list">
          <li>Executive Offices</li>
          <li>Boardrooms &amp; Conference</li>
          <li>Reception &amp; Lobbies</li>
          <li>Boutique Retail</li>
          <li>Commercial Buildouts</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="sector-band sector-band--left">
    <div class="sector-photos" data-photo-rotator>
      {hospitalityPhotos.map((photo, i) => (
        <Image
          src={photo.src}
          alt={photo.alt}
          widths={[1200, 1800, 2400]}
          sizes="100vw"
          loading="lazy"
          class={`sector-photo rotator-photo ${i === 0 ? 'is-active' : ''}`}
        />
      ))}
    </div>
    <div class="sector-overlay"></div>
    <div class="container sector-inner">
      <div class="sector-text reveal">
        <span class="sector-numeral">III</span>
        <span class="eyebrow sector-eyebrow">Sector</span>
        <h3 class="display display-italic sector-headline"><em>Hospitality</em></h3>
        <p class="sector-body">
          Hotel lobbies, restaurant interiors, lounges, atriums, and bars. Hospitality
          design with a service-first eye for flow, durability, and the moments a guest
          actually remembers.
        </p>
        <ul class="sector-list">
          <li>Hotel Lobbies</li>
          <li>Restaurant Interiors</li>
          <li>Lounges &amp; Bars</li>
          <li>Atriums</li>
          <li>Boutique Hospitality</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-bleed-offwhite services-pair">
    <div class="container">
      <div class="pair-grid">
        <a href="/interior-design" class="pair-card reveal">
          <div class="pair-image">
            <Image
              src={hospitalityArtLobby}
              alt="Commercial interior"
              widths={[600, 900, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="pair-body">
            <span class="eyebrow pair-eyebrow">01 &mdash; Service</span>
            <h3 class="display display-italic pair-title"><em>Interior Design</em></h3>
            <p>
              Full interior design for residential, commercial, and hospitality. 2D and
              3D renderings, finish and material selection, furniture and fixtures
              sourcing, project delivery from concept through install.
            </p>
            <span class="pair-link">See interior design &rarr;</span>
          </div>
        </a>

        <a href="/construction" class="pair-card reveal">
          <div class="pair-image">
            <Image
              src={exteriorTraditional}
              alt="Residential exterior"
              widths={[600, 900, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="pair-body">
            <span class="eyebrow pair-eyebrow">02 &mdash; Service</span>
            <h3 class="display display-italic pair-title"><em>Construction</em></h3>
            <p>
              Additions, ground-up new construction, whole-home renovations, and commercial
              buildouts. We build what we design.
            </p>
            <span class="pair-link">See construction &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="pullquote-band">
    <Image
      src={diningElegant}
      alt="Dining interior"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="lazy"
      class="pullquote-bg-photo"
    />
    <div class="pullquote-overlay"></div>
    <div class="container content pullquote-inner reveal">
      <span class="pullquote-mark">&ldquo;</span>
      <p class="pullquote display display-italic">
        Atmosphere is the work. A well-built room with the right proportions, the right
        light, and the right materials feels right to live in for decades.
      </p>
      <GoldRule width="64px" align="center" />
      <p class="pullquote-attribution">Simple &middot; Classic &middot; Timeless</p>
    </div>
  </section>

  <section class="closing-band">
    <Image
      src={hospitalityLounge}
      alt="Hospitality lounge"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="lazy"
      class="closing-bg-photo"
    />
    <div class="closing-overlay"></div>
    <div class="container content closing-inner reveal">
      <span class="eyebrow closing-eyebrow">Begin a project</span>
      <h2 class="display display-italic closing-headline"><em>Planning a project?</em></h2>
      <GoldRule width="64px" align="center" />
      <p class="closing-body">We'd be glad to come take a look. Call or send a request &mdash; we'll get back to you the same day.</p>
      <div class="closing-cta-row">
        <PhoneLink class="btn btn-primary closing-cta" prefix="Call " />
        <TextLink class="btn btn-ghost closing-cta-ghost" label="Request a consultation" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ----- HERO ----- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-white);
  }
  .hero-photos { position: absolute; inset: 0; z-index: 0; }
  .hero-photo, .sector-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.6s ease-in-out;
  }
  .hero-photo.is-active, .sector-photo.is-active { opacity: 1; }
  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15,42,68,0.62) 0%, rgba(15,42,68,0.30) 55%, rgba(15,42,68,0.10) 100%),
      linear-gradient(180deg, rgba(15,42,68,0.20) 0%, rgba(15,42,68,0.0) 35%, rgba(15,42,68,0.0) 65%, rgba(15,42,68,0.45) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
  }
  .hero-text { max-width: 720px; width: 100%; text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35); }
  .hero-eyebrow { color: var(--color-gold); margin-bottom: var(--space-4); text-shadow: none; letter-spacing: 0.28em; }
  .hero-headline {
    color: var(--color-white);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.018em;
    margin-bottom: var(--space-3);
  }
  .hero-headline em { font-style: italic; color: var(--color-white); }
  .hero-subhead {
    color: var(--color-white);
    opacity: 0.94;
    margin-top: var(--space-3);
    margin-bottom: var(--space-6);
    font-size: clamp(var(--text-base), 1.4vw, var(--text-lg));
    max-width: 52ch;
    line-height: 1.65;
    font-weight: 300;
  }
  .hero-cta-row { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-3); }
  .hero-cta {
    background-color: var(--color-white);
    color: var(--color-navy);
    border-color: var(--color-white);
    padding: 16px 36px;
    font-size: var(--text-sm);
    text-decoration: none;
    letter-spacing: 0.14em;
  }
  .hero-cta:hover { background-color: transparent; color: var(--color-white); border-color: var(--color-gold); }
  .hero-cta-ghost {
    background-color: transparent;
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.55);
    padding: 16px 36px;
    font-size: var(--text-sm);
    text-decoration: none;
    letter-spacing: 0.14em;
  }
  .hero-cta-ghost:hover { background-color: transparent; color: var(--color-gold); border-color: var(--color-gold); }
  .hero-scroll-indicator {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-white);
    opacity: 0.7;
  }
  .hero-scroll-label {
    font-family: var(--font-label);
    font-size: 0.65rem;
    letter-spacing: 0.32em;
