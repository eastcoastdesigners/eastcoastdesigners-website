---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldRule from '../components/GoldRule.astro';
import PhoneLink from '../components/PhoneLink.astro';
import TextLink from '../components/TextLink.astro';

// Commercial photography
import commercialBoardroomSkyline from '../assets/images/commercial-boardroom-skyline.jpg';
import commercialExteriorTower from '../assets/images/commercial-exterior-tower.jpg';
import commercialExteriorLimestone from '../assets/images/commercial-exterior-limestone.jpg';
import commercialExteriorRestaurant from '../assets/images/commercial-exterior-restaurant.jpg';
import commercialStorefrontFlagship from '../assets/images/commercial-storefront-flagship.jpg';
import commercialStorefrontBoutique from '../assets/images/commercial-storefront-boutique.jpg';
import commercialLobbyTall from '../assets/images/commercial-lobby-tall.jpg';
import commercialLobbyMarble from '../assets/images/commercial-lobby-marble.jpg';
import commercialReceptionWood from '../assets/images/commercial-reception-wood.jpg';
import commercialLobby from '../assets/images/commercial-lobby.jpg';
import commercialOfficeSkyline from '../assets/images/commercial-office-skyline.jpg';
import commercialExecutiveWood from '../assets/images/commercial-executive-wood.jpg';
import commercialConference from '../assets/images/commercial-conference.jpg';
import commercialLawFirm from '../assets/images/commercial-law-firm.jpg';
import commercialBathMarbleBrass from '../assets/images/commercial-bath-marble-brass.jpg';
import commercialBathDarkStone from '../assets/images/commercial-bath-dark-stone.jpg';
import commercialDetailParquet from '../assets/images/commercial-detail-parquet.jpg';
import commercialLoungeTravertine from '../assets/images/commercial-lounge-travertine.jpg';
import commercialDrywallCove from '../assets/images/commercial-drywall-cove.jpg';
import commercialDrywallRecess from '../assets/images/commercial-drywall-recess.jpg';
import commercialLightingLinear from '../assets/images/commercial-lighting-linear.jpg';
import commercialLightingPendant from '../assets/images/commercial-lighting-pendant.jpg';
import commercialFlooringTerrazzo from '../assets/images/commercial-flooring-terrazzo.jpg';
import commercialFlooringConcrete from '../assets/images/commercial-flooring-concrete.jpg';

const title = 'Our Work — Commercial Portfolio | East Coast Designers';
const description = 'Selected commercial commissions from East Coast Designers — architecture, interiors, storefronts, and the standard of an AD100 firm.';
---
<BaseLayout title={title} description={description} noindex={true}>

  {/* ============================================================
       HERO
       ============================================================ */}
  <section class="ow-hero">
    <Image
      src={commercialBoardroomSkyline}
      alt="Executive boardroom with sweeping skyline view"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      class="ow-hero-bg"
    />
    <div class="ow-hero-overlay"></div>
    <div class="container ow-hero-inner reveal">
      <span class="eyebrow ow-hero-eyebrow">Our Work</span>
      <h1 class="display display-italic ow-hero-headline">
        Rooms treated as <em>masterpieces</em>.
      </h1>
      <GoldRule width="80px" />
      <p class="ow-hero-subhead">
        Selected commercial commissions &mdash; architecture, interiors, storefronts, and
        the trades that build them. Client references given on private inquiry only.
      </p>
    </div>
  </section>

  {/* ============================================================
       INTRO
       ============================================================ */}
  <section class="section ow-intro">
    <div class="container content reveal">
      <span class="eyebrow">The Practice</span>
      <h2 class="display display-italic ow-intro-headline">
        Museum-grade craft for commercial spaces.
      </h2>
      <p>
        We design and build to the standard of an AD100 firm. Material specification
        is decided by the room, not the budget line. Brass is solid. Stone is
        bookmatched. Millwork is hand-finished. The pages below speak to capability,
        client preferences, and the kinds of commissions the studio takes on.
        Specific client references are provided on private inquiry only.
      </p>
    </div>
  </section>

  {/* ============================================================
       SECTOR I — COMMERCIAL
       ============================================================ */}
  <section class="ow-sector ow-sector-commercial">
    <div class="container ow-sector-header reveal">
      <span class="ow-numeral" aria-hidden="true">I</span>
      <span class="eyebrow">Sector I &mdash; Commercial</span>
      <h2 class="display display-italic ow-sector-headline">
        Storefronts, lobbies, <em>and the architecture</em> that contains them.
      </h2>
      <GoldRule width="64px" />
      <p class="ow-sector-lede">
        From limestone facade to bookmatched marble in the executive restroom &mdash;
        every surface specified to a single editorial standard.
      </p>
      <ul class="ow-tags">
        <li>Storefronts &amp; Retail</li>
        <li>Architecture</li>
        <li>Lobbies &amp; Reception</li>
        <li>Office Suites</li>
        <li>Boardrooms</li>
        <li>Bath &amp; Detail</li>
        <li>Floors &amp; Walls</li>
      </ul>
    </div>

    {/* Chapter 1 — Storefronts & Retail (lead with this — partner ask) */}
    <div class="ow-chapter">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Storefronts &amp; Retail</span>
          <p>Retail environments treated as exhibition spaces.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Recent Commission</span>
          <p class="ow-client-brief">Independent flagship retail buildout &mdash; luxury home-goods brand.</p>
          <dl class="ow-client-details">
            <div><dt>Location</dt><dd>Coastal Connecticut</dd></div>
            <div><dt>Scope</dt><dd>Hand-cut limestone facade, brass-trimmed display windows, sage lacquered door, herringbone brick threshold</dd></div>
            <div><dt>Client brief</dt><dd>&ldquo;A museum-grade quiet exterior that earns its dignity from material, not signage.&rdquo;</dd></div>
          </dl>
          <p class="ow-client-foot">References given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialStorefrontBoutique} alt="Empty luxury boutique interior with walnut shelving and terracotta lime-washed wall" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
      <div class="container ow-triptych reveal">
        <Image src={commercialStorefrontFlagship} alt="Flagship store entrance with limestone columns and brass chandelier" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialExteriorLimestone} alt="Luxury retail storefront with limestone facade and sage door" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialExteriorRestaurant} alt="Upscale boutique restaurant exterior at blue hour" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
      </div>
    </div>

    {/* Chapter 2 — Fairfield County Mall (named client commission) */}
    <div class="ow-chapter ow-chapter-named">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Client &mdash; Fairfield County Mall</span>
          <p>Mall-wide interior fit-out &mdash; drywall, lighting, and flooring.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Project</span>
          <p class="ow-client-brief">Fairfield County mall &mdash; interior fit-out across common areas, executive suites, and finishes.</p>
          <dl class="ow-client-details">
            <div><dt>Sector</dt><dd>Retail mall &amp; mixed-use</dd></div>
            <div><dt>Location</dt><dd>Fairfield County, CT</dd></div>
            <div><dt>Scope</dt><dd>Custom drywall (curved coves, recessed display niches), integrated architectural lighting (linear LED, sculptural brass pendants, trimless downlights), terrazzo and polished-concrete flooring</dd></div>
            <div><dt>Trades</dt><dd>Drywall, lighting, flooring &mdash; base building shell to finish</dd></div>
          </dl>
          <p class="ow-client-foot">Specific client reference given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialDrywallCove} alt="Curved drywall cove corridor with integrated cove lighting and walnut paneling" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
      <div class="container ow-triptych reveal">
        <Image src={commercialLightingPendant} alt="Boardroom with sculptural brass pendant cluster over walnut table" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialFlooringTerrazzo} alt="Lobby with large-format terrazzo flooring and brass inlay grid" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialDrywallRecess} alt="Reception wall with recessed display niche and brass picture light" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
      </div>
      <div class="container ow-pair reveal">
        <Image src={commercialLightingLinear} alt="Conference room with continuous linear LED cove lighting and walnut paneling" widths={[600, 900, 1200]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
        <Image src={commercialFlooringConcrete} alt="Polished concrete open office with exposed ceiling and walnut wall" widths={[600, 900, 1200]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy" />
      </div>
    </div>

    {/* Chapter 3 — Architecture (single statement piece) */}
    <div class="ow-chapter">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Architecture</span>
          <p>Buildings designed at the level of street presence, not just program.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Recent Commission</span>
          <p class="ow-client-brief">Mixed-use corporate building &mdash; ground-floor lobby &amp; atrium.</p>
          <dl class="ow-client-details">
            <div><dt>Sector</dt><dd>Financial services tenant</dd></div>
            <div><dt>Location</dt><dd>Fairfield County, CT</dd></div>
            <div><dt>Scope</dt><dd>Curtain-wall facade, travertine base, sculptural brass-clad portal, illuminated lobby visible from street</dd></div>
            <div><dt>Client brief</dt><dd>&ldquo;The lobby is the building&rsquo;s handshake &mdash; design accordingly.&rdquo;</dd></div>
          </dl>
          <p class="ow-client-foot">References given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialExteriorTower} alt="Modern corporate tower exterior at dusk with travertine base" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
    </div>

    {/* Chapter 4 — Lobbies & Reception */}
    <div class="ow-chapter">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Lobbies &amp; Reception</span>
          <p>The first room &mdash; and the one that gets remembered.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Recent Commission</span>
          <p class="ow-client-brief">Corporate headquarters lobby &amp; reception.</p>
          <dl class="ow-client-details">
            <div><dt>Sector</dt><dd>Asset-management firm</dd></div>
            <div><dt>Location</dt><dd>Fairfield County, CT</dd></div>
            <div><dt>Scope</dt><dd>Double-height lobby, bookmatched marble walls, walnut reception millwork, sculptural brass pendant</dd></div>
            <div><dt>Client brief</dt><dd>&ldquo;Serious. Warm. No reception-as-counter aesthetic.&rdquo;</dd></div>
          </dl>
          <p class="ow-client-foot">References given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialLobbyTall} alt="Double-height commercial lobby with sculptural brass pendant" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
      <div class="container ow-triptych reveal">
        <Image src={commercialLobbyMarble} alt="Commercial lobby with bookmatched marble walls" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialReceptionWood} alt="Reception desk with walnut paneling" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialLobby} alt="Modern commercial lobby interior" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
      </div>
    </div>

    {/* Chapter 5 — Office Suites & Boardrooms */}
    <div class="ow-chapter">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Office Suites &amp; Boardrooms</span>
          <p>Workspaces specified at the level of a residence.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Recent Commission</span>
          <p class="ow-client-brief">Private executive suite.</p>
          <dl class="ow-client-details">
            <div><dt>Sector</dt><dd>Multi-generational family office</dd></div>
            <div><dt>Location</dt><dd>New York metro area</dd></div>
            <div><dt>Scope</dt><dd>Bookmatched walnut paneling, custom millwork shelving, integrated AV, dimmable scene lighting</dd></div>
            <div><dt>Client brief</dt><dd>&ldquo;Specified for the principal who works late &mdash; warmth at night, under controlled lighting.&rdquo;</dd></div>
          </dl>
          <p class="ow-client-foot">References given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialOfficeSkyline} alt="Private executive office with skyline view" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
      <div class="container ow-triptych reveal">
        <Image src={commercialExecutiveWood} alt="Executive office with walnut paneling" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialConference} alt="Conference room with editorial styling" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialLawFirm} alt="Private law-firm partner office" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
      </div>
    </div>

    {/* Chapter 6 — Interiors / Bath / Floors / Walls */}
    <div class="ow-chapter">
      <div class="container ow-chapter-intro reveal">
        <div class="ow-chapter-text">
          <span class="eyebrow">Interiors &mdash; Bath, Floors, Walls</span>
          <p>The decisions that distinguish good work from masterpiece.</p>
        </div>
        <aside class="ow-client-card">
          <span class="eyebrow ow-client-eyebrow">Recent Commission</span>
          <p class="ow-client-brief">Executive restroom &amp; corridor finishes &mdash; corporate fit-out.</p>
          <dl class="ow-client-details">
            <div><dt>Sector</dt><dd>Corporate tenant build-out</dd></div>
            <div><dt>Location</dt><dd>Westchester County, NY</dd></div>
            <div><dt>Scope</dt><dd>Bookmatched Calacatta marble, polished brass tapware, walnut vanity, herringbone parquet with brass inlay</dd></div>
            <div><dt>Client brief</dt><dd>&ldquo;No executive restroom should look like one.&rdquo;</dd></div>
          </dl>
          <p class="ow-client-foot">References given on private inquiry only.</p>
        </aside>
      </div>
      <figure class="ow-feature reveal">
        <Image src={commercialBathMarbleBrass} alt="Executive restroom with Calacatta marble and brass tapware" widths={[1200, 1800, 2400]} sizes="100vw" loading="lazy" />
      </figure>
      <div class="container ow-triptych reveal">
        <Image src={commercialBathDarkStone} alt="Corporate restroom with dark Pietra Cardosa stone" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialDetailParquet} alt="Herringbone parquet floor with brass inlay" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
        <Image src={commercialLoungeTravertine} alt="Commercial lounge with travertine surfaces" widths={[500, 800, 1100]} sizes="(min-width: 900px) 33vw, 100vw" loading="lazy" />
      </div>
    </div>
  </section>

  {/* ============================================================
       PULL QUOTE (navy band)
       ============================================================ */}
  <section class="ow-pull">
    <div class="container content reveal">
      <p class="display display-italic ow-pull-quote">
        Every room is treated as a single, considered work of art.
      </p>
      <GoldRule width="48px" align="center" />
      <span class="eyebrow ow-pull-attr">The Studio</span>
    </div>
  </section>


  {/* ============================================================
       CTA
       ============================================================ */}
  <section class="ow-cta">
    <div class="container content reveal">
      <span class="eyebrow">To Continue The Conversation</span>
      <h2 class="display display-italic ow-cta-headline">
        Let&rsquo;s walk through it.
      </h2>
      <GoldRule width="56px" align="center" />
      <p class="ow-cta-body">
        Call directly or request a consultation. Client references are provided on
        private inquiry &mdash; we respond the same day.
      </p>
      <div class="ow-cta-row">
        <PhoneLink class="btn btn-primary ow-cta-btn" prefix="Call " />
        <TextLink class="btn btn-secondary ow-cta-btn" label="Request a consultation" />
      </div>
    </div>
  </section>

  <script>
    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && reveals.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach((el) => observer.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('is-visible'));
    }
  </script>

</BaseLayout>

<style>
  /* HERO */
  .ow-hero {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-white);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }
  .ow-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0.58;
  }
  .ow-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15,42,68,0.45) 0%, rgba(15,42,68,0.82) 100%);
    z-index: 1;
  }
  .ow-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }
  .ow-hero-eyebrow {
    color: var(--color-gold);
    letter-spacing: 0.34em;
  }
  .ow-hero-headline {
    color: var(--color-white);
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    line-height: 1.01;
    letter-spacing: -0.022em;
    margin-bottom: var(--space-3);
  }
  .ow-hero-headline em { font-style: italic; color: var(--color-white); }
  .ow-hero-subhead {
    color: var(--color-white);
    opacity: 0.93;
    font-size: clamp(var(--text-base), 1.4vw, var(--text-xl));
    margin-top: var(--space-4);
    max-width: 60ch;
    font-weight: 300;
    line-height: 1.65;
  }

  /* INTRO */
  .ow-intro {
    background-color: var(--color-offwhite);
    padding-top: clamp(var(--space-16), 12vw, 9rem);
    padding-bottom: clamp(var(--space-16), 12vw, 9rem);
    text-align: center;
  }
  .ow-intro-headline {
    font-size: clamp(2rem, 4.5vw, 3rem);
    color: var(--color-navy);
    margin: var(--space-3) 0 var(--space-4);
    font-weight: 400;
    line-height: 1.05;
  }
  .ow-intro p {
    color: var(--color-body);
    font-weight: 300;
    max-width: 68ch;
    margin: 0 auto;
  }

  /* SECTOR HEADER */
  .ow-sector {
    padding-top: clamp(var(--space-16), 12vw, 9rem);
    padding-bottom: clamp(var(--space-16), 12vw, 9rem);
    background-color: var(--color-white);
  }
  .ow-sector-header {
    position: relative;
    max-width: 880px;
    margin-bottom: clamp(var(--space-12), 8vw, var(--space-16));
  }
  .ow-numeral {
    position: absolute;
    top: -0.4em;
    right: -0.05em;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(7rem, 18vw, 14rem);
    color: var(--color-gold);
    opacity: 0.16;
    line-height: 1;
    letter-spacing: -0.02em;
    pointer-events: none;
    font-weight: 300;
  }
  .ow-sector-headline {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.02;
    color: var(--color-navy);
    margin: var(--space-2) 0 var(--space-3);
    font-weight: 400;
    letter-spacing: -0.018em;
    max-width: 18ch;
    position: relative;
    z-index: 1;
  }
  .ow-sector-headline em { font-style: italic; }
  .ow-sector-lede {
    color: var(--color-body);
    font-size: clamp(var(--text-lg), 1.4vw, var(--text-xl));
    font-weight: 300;
    line-height: 1.7;
    max-width: 60ch;
    margin: var(--space-4) 0;
    position: relative;
    z-index: 1;
  }
  .ow-tags {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    position: relative;
    z-index: 1;
  }
  .ow-tags li {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-navy);
    font-weight: 500;
    padding: 0 var(--space-3);
    border-right: 1px solid var(--color-gold);
  }
  .ow-tags li:first-child { padding-left: 0; }
  .ow-tags li:last-child { border-right: none; padding-right: 0; }

  /* CHAPTER */
  .ow-chapter {
    margin-top: clamp(var(--space-12), 9vw, var(--space-16));
  }
  .ow-chapter-intro {
    margin-bottom: var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  @media (min-width: 900px) {
    .ow-chapter-intro {
      grid-template-columns: 5fr 4fr;
      gap: clamp(var(--space-6), 5vw, var(--space-8));
    }
  }
  .ow-chapter-text {
    max-width: 56ch;
  }
  .ow-chapter-text p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--color-navy);
    font-size: clamp(var(--text-xl), 2.2vw, 1.75rem);
    line-height: 1.3;
    margin: var(--space-2) 0 0;
    letter-spacing: -0.005em;
  }

  /* CLIENT CARD */
  .ow-client-card {
    background-color: var(--color-offwhite);
    border-left: 2px solid var(--color-gold);
    padding: var(--space-4) var(--space-4) var(--space-3);
  }
  .ow-client-eyebrow {
    color: var(--color-gold);
    letter-spacing: 0.28em;
  }
  .ow-client-brief {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--color-navy);
    font-size: var(--text-xl);
    line-height: 1.25;
    margin: var(--space-1) 0 var(--space-3);
    letter-spacing: -0.005em;
  }
  .ow-client-details {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  .ow-client-details > div {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--space-2);
    align-items: baseline;
  }
  .ow-client-details dt {
    font-family: var(--font-label);
    font-size: var(--text-xs);
