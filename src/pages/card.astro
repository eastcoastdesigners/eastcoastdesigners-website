---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GoldRule from '../components/GoldRule.astro';
import logoMetallic from '../assets/logos/logo-metallic.png';
import marbleBg from '../assets/marble-card-background.jpg';
import qrChair from '../assets/qr-with-chair.svg';

const title = 'Cristina — East Coast Designers';
const description = 'Digital business card for Cristina at East Coast Designers — design and construction practice. Connecticut.';
---
<BaseLayout title={title} description={description} noindex={true}>

  <section class="card-stage">
    <Image
      src={marbleBg}
      alt=""
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      class="card-stage-bg"
      aria-hidden="true"
    />
    <div class="card-stage-overlay" aria-hidden="true"></div>

    <article class="card reveal">
      <div class="card-logo">
        <Image
          src={logoMetallic}
          alt="East Coast Designers"
          widths={[260, 400, 560, 720]}
          sizes="(min-width: 600px) 300px, 220px"
          loading="eager"
        />
      </div>

      <div class="card-name">
        <h1 class="display display-italic card-name-text">Cristina</h1>
        <p class="card-title">Designer &amp; General Contractor</p>
        <p class="card-locations">New York &mdash; Connecticut</p>
      </div>

      <GoldRule width="56px" align="center" />

      <ul class="card-contact" aria-label="Contact">
        <li>
          <a href="tel:+12032289197" class="card-link" aria-label="Call (203) 228-9197">
            <span class="card-link-label">Tel</span>
            <span class="card-link-value">(203) 228-9197</span>
          </a>
        </li>
        <li>
          <a href="https://www.eastcoastdesigners.com" class="card-link" aria-label="Visit eastcoastdesigners.com">
            <span class="card-link-label">Web</span>
            <span class="card-link-value">eastcoastdesigners.com</span>
          </a>
        </li>
      </ul>

      <div class="card-footer">
        <span class="card-tagline">By Referral Only</span>
        <a
          href="https://www.eastcoastdesigners.com"
          class="card-qr"
          aria-label="QR code linking to eastcoastdesigners.com"
        >
          <img src={qrChair.src} alt="QR code linking to eastcoastdesigners.com" width="140" height="140" />
        </a>
      </div>
    </article>
  </section>

  <script>
    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && reveals.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      reveals.forEach((el) => observer.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('is-visible'));
    }
  </script>

</BaseLayout>

<style>
  /* PAGE BACKGROUND — marble photo full-bleed */
  .card-stage {
    position: relative;
    min-height: 100vh;
    padding: clamp(var(--space-6), 8vw, var(--space-12)) var(--gutter);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-stage-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .card-stage-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center,
      rgba(0,0,0,0.0) 0%,
      rgba(0,0,0,0.0) 40%,
      rgba(0,0,0,0.15) 100%);
    z-index: 1;
  }

  /* CARD SURFACE — dark, embossed look, sitting on marble */
  .card {
    position: relative;
    z-index: 2;
    background-color: #0a0a0a;
    background-image:
      linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(0,0,0,0.0) 50%, rgba(0,0,0,0.4) 100%);
    width: 100%;
    max-width: 640px;
    padding: clamp(var(--space-8), 8vw, var(--space-12)) clamp(var(--space-6), 6vw, var(--space-8));
    border: 1px solid rgba(201, 169, 97, 0.18);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.4),
      0 18px 40px rgba(0, 0, 0, 0.35),
      0 40px 96px rgba(0, 0, 0, 0.4);
    text-align: center;
  }

  /* LOGO */
  .card-logo {
    margin-bottom: var(--space-3);
  }
  .card-logo :global(img) {
    width: clamp(240px, 50%, 320px);
    height: auto;
    display: block;
    margin: 0 auto;
  }

  /* NAME */
  .card-name {
    margin: var(--space-3) 0 var(--space-4);
  }
  .card-name-text {
    font-size: clamp(3rem, 7vw, 4.5rem);
    line-height: 1;
    color: #f0e9d8;
    margin: 0 0 var(--space-2);
    font-weight: 400;
    letter-spacing: -0.012em;
  }
  .card-title {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 500;
    margin: 0;
  }
  .card-locations {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-base);
    color: #f0e9d8;
    opacity: 0.8;
    margin: var(--space-1) 0 0;
    letter-spacing: 0.02em;
  }

  /* CONTACT */
  .card-contact {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }
  .card-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    text-decoration: none;
    color: #f0e9d8;
    transition: color 0.15s;
  }
  .card-link:hover { color: var(--color-gold); }
  .card-link-label {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }
  .card-link-value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(var(--text-xl), 2.6vw, 1.85rem);
    color: #f0e9d8;
    letter-spacing: -0.005em;
  }

  /* FOOTER WITH QR */
  .card-footer {
    margin-top: clamp(var(--space-6), 6vw, var(--space-8));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .card-tagline {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
    text-align: left;
  }
  .card-qr {
    display: inline-block;
    line-height: 0;
    padding: 10px;
    background-color: var(--color-white);
    border: 1px solid rgba(201, 169, 97, 0.4);
    transition: border-color 0.15s;
  }
  .card-qr:hover { border-color: var(--color-gold); }
  .card-qr img {
    width: clamp(110px, 24vw, 140px);
    height: auto;
    display: block;
  }

  @media (max-width: 480px) {
    .card-footer {
      flex-direction: column-reverse;
      gap: var(--space-3);
    }
    .card-tagline {
      text-align: center;
    }
  }
</style>
