---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLink from '../components/PhoneLink.astro';
import TextLink from '../components/TextLink.astro';
import GoldRule from '../components/GoldRule.astro';

import idHero from '../assets/images/dining-chandelier.jpg';
import livingHero from '../assets/images/hero-living.jpg';
import livingFireplace from '../assets/images/living-fireplace.jpg';
import livingWarm from '../assets/images/living-warm.jpg';
import bathMarble from '../assets/images/bath-marble.jpg';
import kitchenMarble from '../assets/images/kitchen-marble.jpg';
import diningElegant from '../assets/images/dining-elegant.jpg';

const title = 'Interior Design — Renderings, Sourcing, Full Service | East Coast Designers';
const description = 'Full interior design. 2D and 3D renderings, finish and material selection, furniture and fixtures sourcing. Residential and commercial. Based in Connecticut, working tri-state and select projects nationwide.';
---
<BaseLayout title={title} description={description}>

  <section class="page-hero">
    <Image
      src={idHero}
      alt="Dining room"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      class="page-hero-photo"
    />
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-inner">
      <span class="eyebrow page-hero-eyebrow">Interior Design</span>
      <h1>Designed to live in.</h1>
      <GoldRule width="64px" />
      <p class="page-hero-subhead">
        Full interior design. Renderings, finish and material selection, sourcing —
        residential and commercial.
      </p>
    </div>
  </section>

  <section class="section services-block">
    <div class="container">
      <div class="services-header">
        <span class="eyebrow">What we do</span>
        <h2>From first concept to final install.</h2>
        <GoldRule width="64px" />
      </div>
      <div class="services-list">
        <article class="service-row">
          <span class="service-num">01</span>
          <div class="service-body">
            <h3>Full Interior Design</h3>
            <p>
              Residential and commercial interior design — concept, layout, palette,
              specifications. We work on whole homes, single rooms, and commercial
              interiors with the same care and considered detail.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">02</span>
          <div class="service-body">
            <h3>2D and 3D Renderings</h3>
            <p>
              Renderings let you see the space before we build it. We produce 2D plans
              and 3D walk-throughs so you can refine decisions when they're still
              inexpensive to change.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">03</span>
          <div class="service-body">
            <h3>Finish &amp; Material Selection</h3>
            <p>
              Stone, tile, cabinetry, flooring, hardware, lighting, paint. We source and
              specify the materials that hold up — visually and physically — and
              coordinate them so the finished room feels right.
            </p>
          </div>
        </article>
        <article class="service-row">
          <span class="service-num">04</span>
          <div class="service-body">
            <h3>Furniture &amp; Fixtures Sourcing</h3>
            <p>
              Furniture, fixtures, lighting, and accessories — sourced and installed.
              We handle the procurement so the finished room is complete on day one.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-bleed-offwhite philosophy-band">
    <div class="container content philosophy-inner">
      <span class="eyebrow">Approach</span>
      <h2 class="philosophy-mark">Simple. Classic. Timeless.</h2>
      <GoldRule width="64px" align="center" />
      <p class="philosophy-body">
        We design for the room that will still feel right in twenty years. Proportions
        considered. Materials that age well. Light handled with care. The work is
        residential at heart, even when the room is commercial — because comfort,
        atmosphere, and warmth read the same in any building.
      </p>
    </div>
  </section>

  <section class="section portfolio-section">
    <div class="container">
      <div class="portfolio-header">
        <span class="eyebrow">Work</span>
        <h2>Interiors, residential and commercial.</h2>
      </div>
      <div class="portfolio-grid">
        <figure class="portfolio-tile">
          <Image
            src={livingHero}
            alt="Living room"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Living room design</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={diningElegant}
            alt="Dining room"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Dining room design</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={kitchenMarble}
            alt="Kitchen renovation"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Kitchen design</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={livingFireplace}
            alt="Living room"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Sitting room with fireplace</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={bathMarble}
            alt="Bathroom design"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Primary bath design</figcaption>
        </figure>
        <figure class="portfolio-tile">
          <Image
            src={livingWarm}
            alt="Living room"
            widths={[600, 900, 1200]}
            sizes="(min-width: 960px) 50vw, 100vw"
            loading="lazy"
          />
          <figcaption>Whole-home design</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-bleed-navy closing-band">
    <div class="container content">
      <h2>Planning an interior design project?</h2>
      <p class="closing-body">We'd be glad to come take a look. Call or send a request — we'll get back to you the same day.</p>
      <div class="closing-cta-row">
        <PhoneLink class="btn btn-primary closing-cta" prefix="Call " />
        <TextLink class="btn btn-ghost closing-cta-ghost" label="Request a consultation" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-white);
  }
  .page-hero-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .page-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(15,42,68,0.4) 0%, rgba(15,42,68,0.82) 100%);
    z-index: 1;
  }
  .page-hero-inner {
    position: relative; z-index: 2;
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    max-width: 820px;
  }
  .page-hero-eyebrow { color: var(--color-gold); margin-bottom: var(--space-3); }
  .page-hero h1 {
    color: var(--color-white);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .page-hero-subhead {
    color: var(--color-white);
    opacity: 0.94;
    margin-top: var(--space-3);
    font-size: clamp(var(--text-lg), 1.5vw, var(--text-xl));
    max-width: 56ch;
    line-height: 1.55;
  }

  .services-block {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .services-header { max-width: 720px; margin-bottom: var(--space-8); }
  .services-header h2 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    line-height: 1.15;
    margin-top: var(--space-2);
  }
  .services-list { display: flex; flex-direction: column; gap: var(--space-6); max-width: 820px; }
  .service-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(15, 42, 68, 0.08);
  }
  .service-row:last-child { border-bottom: none; padding-bottom: 0; }
  .service-num {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    line-height: 1;
    opacity: 0.85;
  }
  .service-body h3 {
    font-size: var(--text-xl);
    margin-top: -0.15em;
    margin-bottom: var(--space-2);
    color: var(--color-navy);
  }
  .service-body p {
    font-size: var(--text-base);
    color: var(--color-body);
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }

  .philosophy-band {
    padding-top: clamp(var(--space-16), 12vw, 8rem);
    padding-bottom: clamp(var(--space-16), 12vw, 8rem);
  }
  .philosophy-inner { text-align: center; max-width: 720px; }
  .philosophy-mark {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-4xl), 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    margin: var(--space-3) 0;
    font-style: italic;
    font-weight: 400;
  }
  .philosophy-body {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.7;
    margin-top: var(--space-4);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .portfolio-section {
    padding-top: clamp(var(--space-12), 10vw, var(--space-16));
    padding-bottom: clamp(var(--space-12), 10vw, var(--space-16));
  }
  .portfolio-header { max-width: 720px; margin-bottom: var(--space-8); }
  .portfolio-header h2 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    line-height: 1.15;
    margin-top: var(--space-2);
  }
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1200px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr 1fr; }
  }
  .portfolio-tile { margin: 0; }
  .portfolio-tile :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    display: block;
  }
  .portfolio-tile figcaption {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    letter-spacing: var(--label-letter-spacing);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: var(--space-2);
  }

  .closing-band { text-align: center; padding-top: var(--space-16); padding-bottom: var(--space-16); }
  .closing-band h2 {
    margin-bottom: var(--space-3);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
  }
  .closing-body {
    color: var(--color-white);
    opacity: 0.94;
    margin-bottom: var(--space-6);
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }
  .closing-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }
  .closing-cta {
    background-color: var(--color-white);
    color: var(--color-navy);
    border-color: var(--color-white);
    padding: 14px 32px;
    text-decoration: none;
  }
  .closing-cta:hover {
    background-color: transparent;
    color: var(--color-white);
    border-color: var(--color-gold);
  }
  .closing-cta-ghost {
    background-color: transparent;
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
    padding: 14px 32px;
    text-decoration: none;
  }
  .closing-cta-ghost:hover {
    background-color: transparent;
    color: var(--color-gold);
    border-color: var(--color-gold);
  }
</style>
